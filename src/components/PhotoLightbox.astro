---

---

<div
  id="photo-lightbox"
  class="fixed inset-0 z-[200] hidden items-center justify-center p-6 sm:p-10 md:p-16"
  role="dialog"
  aria-modal="true"
  aria-label="Photo lightbox"
>
  <div
    id="lightbox-backdrop"
    class="absolute inset-0 bg-dark-green/70 backdrop-blur-sm transition-opacity duration-300 opacity-0"
  >
  </div>
  <img
    id="lightbox-img"
    src=""
    alt=""
    class="relative z-10 max-w-full max-h-full rounded-3xl shadow-2xl object-contain transition-all duration-300 scale-95 opacity-0"
  />
  <button
    type="button"
    id="lightbox-close"
    class="absolute top-4 right-4 z-20 text-cream/80 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
    aria-label="Close"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>

<script>
  // Ensure the script runs once and correctly binds to the DOM elements.
  const setupLightbox = () => {
    const lightbox = document.getElementById(
      "photo-lightbox",
    ) as HTMLDivElement;
    if (!lightbox) return; // Prevent errors if component isn't on page

    const lightboxImg = document.getElementById(
      "lightbox-img",
    ) as HTMLImageElement;
    const lightboxBackdrop = document.getElementById(
      "lightbox-backdrop",
    ) as HTMLDivElement;
    const lightboxClose = document.getElementById(
      "lightbox-close",
    ) as HTMLButtonElement;

    function openLightbox(src: string, alt: string) {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      requestAnimationFrame(() => {
        lightboxBackdrop.classList.remove("opacity-0");
        lightboxBackdrop.classList.add("opacity-100");
        lightboxImg.classList.remove("scale-95", "opacity-0");
        lightboxImg.classList.add("scale-100", "opacity-100");
      });
    }

    function closeLightbox() {
      lightboxBackdrop.classList.remove("opacity-100");
      lightboxBackdrop.classList.add("opacity-0");
      lightboxImg.classList.remove("scale-100", "opacity-100");
      lightboxImg.classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        lightboxImg.src = "";
      }, 300);
    }

    document.querySelectorAll(".lightbox-trigger").forEach((btn) => {
      // Use event delegation or avoid duplicate listeners if this script runs multiple times
      // Since it's a module script in Astro, it runs once per page load.
      btn.addEventListener("click", () => {
        const src = (btn as HTMLElement).dataset.fullSrc || "";
        const alt = btn.querySelector("img")?.alt || "";
        openLightbox(src, alt);
      });
    });

    lightboxClose.addEventListener("click", closeLightbox);
    lightboxBackdrop.addEventListener("click", closeLightbox);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lightbox.classList.contains("hidden")) {
        closeLightbox();
      }
    });
  };

  setupLightbox();
</script>
