---
import { Icon } from "astro-icon/components";
const currentYear = new Date().getFullYear();
---

<footer class="w-full flex justify-center pb-6 px-4">
  <div
    class="glass-card shadow-[0_8px_30px_rgb(0,0,0,0.06)] rounded-[2rem] px-8 py-4 flex flex-col md:flex-row items-center justify-between gap-4 md:gap-8 min-w-[300px]"
  >
    <p class="text-sm text-dark-green font-medium tracking-wide text-center md:text-left">
      &copy; {currentYear} Telperion z.s.
    </p>
    <div class="flex items-center gap-4">
      <a
        href="https://www.instagram.com/telperion.cz/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-dark-green hover:text-brand-green transition-colors duration-200"
      >
        <Icon name="mdi:instagram" class="w-6 h-6" />
      </a>
      <a
        href="https://www.youtube.com/@telperion-cz/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="YouTube"
        class="text-dark-green hover:text-brand-green transition-colors duration-200"
      >
        <Icon name="mdi:youtube" class="w-6 h-6" />
      </a>
    </div>
  </div>
</footer>
