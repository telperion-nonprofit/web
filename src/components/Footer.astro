---
const currentYear = new Date().getFullYear();
---

<footer class="w-full flex justify-center pb-6">
  <div
    class="glass-card shadow-[0_8px_30px_rgb(0,0,0,0.06)] rounded-[2rem] px-8 py-4 transition-transform hover:-translate-y-1 duration-300 flex items-center gap-4"
  >
    <p class="text-sm text-dark-green font-medium tracking-wide">
      &copy; {currentYear} Telperion z.s.
    </p>
    <a
      href="https://www.instagram.com/telperion.cz/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram"
      class="text-dark-green hover:text-green-700 transition-colors duration-200"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
      </svg>
    </a>
  </div>
</footer>
