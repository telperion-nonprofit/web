---
const currentYear = new Date().getFullYear();
---

<footer class="w-full flex justify-center pb-6">
  <div
    class="glass-card shadow-[0_8px_30px_rgb(0,0,0,0.06)] rounded-[2rem] px-8 py-4 transition-transform hover:-translate-y-1 duration-300 flex items-center gap-4"
  >
    <p class="text-sm text-dark-green font-medium tracking-wide">
      &copy; {currentYear} Telperion z.s.
    </p>
    <a
      href="https://www.instagram.com/telperion.cz/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram"
      class="text-dark-green hover:text-green-700 transition-colors duration-200"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
      </svg>
    </a>
    <a
      href="https://www.youtube.com/@telperion-cz/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="YouTube"
      class="text-dark-green hover:text-green-700 transition-colors duration-200"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"
        ></path>
        <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
      </svg>
    </a>
  </div>
</footer>
