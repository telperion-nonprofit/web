---
import { useTranslations, replacePlaceholders } from "../utils/i18n";
import type { Locale } from "../utils/i18n";
const lang = (Astro.currentLocale as Locale) || "cs";
const t = useTranslations(lang);
import type { MenuItem } from "../types";
import DesktopMenuItem from "./navbar/DesktopMenuItem.astro";
import MobileMenuItem from "./navbar/MobileMenuItem.astro";
import LanguageDropdown from "./LanguageDropdown.astro";
import { Image } from "astro:assets";
import logoImg from "../assets/logo.png";
import { getRelativeLocaleUrl } from "astro:i18n";
import { routeMap } from "../utils/lang";

const getUrl = (path: string) => {
  if (path === "#") return path;
  if (lang === "cs") return path;

  // If english, check if there's a mapped route
  if (routeMap[path]) {
    return routeMap[path];
  }

  // Handle dynamic slugs (e.g. /clanky/foo) by checking if the path starts with a mapped base route
  for (const [czBase, enBase] of Object.entries(routeMap)) {
    if (path.startsWith(`${czBase}/`)) {
      return path.replace(czBase, enBase);
    }
  }

  return getRelativeLocaleUrl(lang, path);
};

const menuItems: MenuItem[] = [
  { name: t("nav.home"), url: getUrl("/") },
  {
    name: t("nav.programs"),
    url: "#",
    subItems: [
      { name: t("nav.programs_schools"), url: getUrl("/programy/pro-skoly") },
      {
        name: t("nav.programs_public"),
        url: getUrl("/programy/pro-verejnost"),
      },
      {
        name: t("nav.programs_other"),
        url: getUrl("/programy/dalsi-programy"),
      },
    ],
  },
  { name: t("nav.podcast"), url: getUrl("/podcast") },
  { name: t("nav.articles"), url: getUrl("/clanky") },
  { name: t("nav.contact"), url: getUrl("/kontakty") },
];
---

<header
  class="fixed top-4 left-0 right-0 z-50 px-4 sm:px-6 lg:px-8 transition-all duration-300 pointer-events-none"
>
  <div class="relative mx-auto max-w-6xl px-6 py-3 pointer-events-auto">
    <div class="absolute inset-0 glass-card shadow-sm rounded-full -z-10"></div>

    <div class="relative z-10 flex items-center justify-between h-10 lg:h-12">
      <div class="flex-shrink-0 z-20">
        <a href={getUrl("/")} class="flex items-center gap-2 group">
          <Image
            src={logoImg}
            alt="Telperion Logo"
            fetchpriority="high"
            loading="eager"
            widths={[100, 200]}
            sizes="(max-width: 1024px) 40px, 48px"
            class="h-10 lg:h-12 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
          />
        </a>
      </div>

      <nav
        class="hidden lg:flex flex-1 justify-center items-center pointer-events-none z-10 px-4"
      >
        <ul
          class="flex items-center space-x-1 lg:space-x-4 pointer-events-auto"
        >
          {menuItems.map((item) => <DesktopMenuItem item={item} />)}
        </ul>
      </nav>

      <div
        class="hidden lg:flex flex-shrink-0 items-center gap-2 z-20 pointer-events-auto"
      >
        <LanguageDropdown />
        <button
          type="button"
          onclick="document.dispatchEvent(new CustomEvent('open-donation-modal'))"
          class="bg-brand-green text-cream px-6 py-2.5 rounded-full font-bold text-sm hover:bg-dark-green transition-colors focus:outline-none focus:ring-2 focus:ring-brand-green focus:ring-offset-2 shadow-lg shadow-brand-green/20"
        >
          {t("nav.button.donate")}
        </button>
      </div>

      <div class="lg:hidden flex items-center z-20">
        <button
          id="mobile-menu-btn"
          type="button"
          class="group text-dark-green hover:text-brand-green focus:outline-none p-2 bg-white/50 rounded-full transition-colors"
          aria-label="Otevřít menu"
          aria-expanded="false"
        >
          <svg
            class="hamburger-icon h-6 w-6 block group-aria-expanded:hidden"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            class="close-icon h-6 w-6 hidden group-aria-expanded:block"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden lg:hidden mt-2 mx-auto max-w-6xl pointer-events-auto origin-top transition-all duration-300 ease-in-out"
  >
    <div
      class="glass-card rounded-3xl shadow-lg px-4 pt-4 pb-6 space-y-2"
    >
      {menuItems.map((item) => <MobileMenuItem item={item} />)}
      <div class="pt-4 mt-2 border-t border-brand-green/10 space-y-4">
        <LanguageDropdown mobile={true} />
        <button
          type="button"
          onclick="document.dispatchEvent(new CustomEvent('open-donation-modal'))"
          class="block w-full text-center bg-brand-green text-cream px-6 py-3.5 rounded-full font-bold hover:bg-dark-green transition-colors focus:outline-none focus:ring-2 focus:ring-brand-green focus:ring-offset-2 shadow-lg shadow-brand-green/20"
        >
          {t("nav.button.donate")}
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    if (btn && menu) {
      btn.addEventListener("click", () => {
        const isExpanded = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!isExpanded));
        menu.classList.toggle("hidden");
      });
    }
  });
</script>
