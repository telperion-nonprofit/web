---
import type { MenuItem } from '../types';
import DesktopMenuItem from './navbar/DesktopMenuItem.astro';
import MobileMenuItem from './navbar/MobileMenuItem.astro';
import LanguageDropdown from './LanguageDropdown.astro';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';

const menuItems: MenuItem[] = [
  { name: 'Domů', url: '/' },
  { 
    name: 'Programy', 
    url: '#',
    subItems: [
      { name: 'Pro školy', url: '/programy/pro-skoly' },
      { name: 'Pro veřejnost', url: '/programy/pro-verejnost' },
      { name: 'Další programy', url: '/programy/dalsi-programy' },
    ]
  },
  { name: 'Podcast', url: '/podcast' },
  { name: 'Články', url: '/clanky' },
  { name: 'Kontakty', url: '/kontakty' },
];
---

<header class="fixed top-4 left-0 right-0 z-50 px-4 sm:px-6 lg:px-8 transition-all duration-300 pointer-events-none">
  
  <div class="relative mx-auto max-w-6xl px-6 py-3 pointer-events-auto">
    <div class="absolute inset-0 glass-card shadow-sm rounded-full -z-10"></div>
    
    <div class="relative z-10 flex items-center justify-between h-10 md:h-12">
      
      <div class="flex-shrink-0 z-20">
        <a href="/" class="flex items-center gap-2 group">
          <Image 
            src={logoImg} 
            alt="Telperion Logo" 
            fetchpriority="high"
            loading="eager"
            class="h-10 md:h-12 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
          />
        </a>
      </div>

      <nav class="hidden md:flex absolute inset-x-0 top-0 bottom-0 justify-center items-center pointer-events-none z-10">
        <ul class="flex items-center space-x-1 lg:space-x-4 pointer-events-auto">
          {menuItems.map((item) => (
            <DesktopMenuItem item={item} />
          ))}
        </ul>
      </nav>

      <div class="hidden md:flex items-center gap-2 z-20 pointer-events-auto">
        <LanguageDropdown />
        <button 
          type="button" 
          onclick="document.dispatchEvent(new CustomEvent('open-contact-modal'))" 
          class="bg-brand-green text-cream px-6 py-2.5 rounded-full font-bold text-sm hover:bg-dark-green transition-colors focus:outline-none focus:ring-2 focus:ring-brand-green focus:ring-offset-2 shadow-lg shadow-brand-green/20"
        >
          [[nav.button.book]]
        </button>
      </div>

      <div class="md:hidden flex items-center z-20">
        <button 
          id="mobile-menu-btn" 
          type="button"
          class="group text-dark-green hover:text-brand-green focus:outline-none p-2 bg-white/50 rounded-full transition-colors" 
          aria-label="Otevřít menu" 
          aria-expanded="false"
        >
          <svg class="hamburger-icon h-6 w-6 block group-aria-expanded:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="close-icon h-6 w-6 hidden group-aria-expanded:block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden mt-2 mx-auto max-w-6xl pointer-events-auto origin-top transition-all duration-300 ease-in-out">
    <div class="glass-card rounded-3xl shadow-lg px-4 pt-4 pb-6 space-y-2 border border-brand-green/10">
      {menuItems.map((item) => (
        <MobileMenuItem item={item} />
      ))}
      <div class="pt-4 mt-2 border-t border-brand-green/10 space-y-4">
        <LanguageDropdown mobile={true} />
        <button 
          type="button" 
          onclick="document.dispatchEvent(new CustomEvent('open-contact-modal'))" 
          class="block w-full text-center bg-brand-green text-cream px-6 py-3.5 rounded-full font-bold hover:bg-dark-green transition-colors focus:outline-none focus:ring-2 focus:ring-brand-green focus:ring-offset-2 shadow-lg shadow-brand-green/20"
        >
          Poptat program
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (btn && menu) {
      btn.addEventListener('click', () => {
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!isExpanded));
        menu.classList.toggle('hidden');
      });
    }
  });
</script>