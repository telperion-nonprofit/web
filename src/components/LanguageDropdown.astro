---
import { Icon } from "astro-icon/components";
import { translatePath } from "../utils/lang";

interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;

// Strip trailing slash except for root paths
let currentPath = Astro.url.pathname;
if (
  currentPath !== "/" &&
  currentPath !== "/en/" &&
  currentPath.endsWith("/")
) {
  currentPath = currentPath.slice(0, -1);
}

const isEn = currentPath === "/en" || currentPath.startsWith("/en/");
const currentLabel = isEn ? "EN" : "CS";
const isStatusPath = /^\/(en\/)?(404|500)\/?$/.test(currentPath);

let csPath = "/";
let enPath = "/en/";

if (isStatusPath) {
  csPath = "/";
  enPath = "/en/";
} else {
  if (isEn) {
    enPath = currentPath;
    csPath = translatePath(currentPath, "cs");
  } else {
    csPath = currentPath || "/";
    enPath = translatePath(currentPath, "en");
  }
}
---

<div
  class={`relative language-dropdown-container ${mobile ? "w-full" : "inline-block"}`}
>
  <button
    type="button"
    class={`language-toggle flex items-center justify-between gap-2 px-4 py-2 text-sm font-medium transition-colors ${
      mobile
        ? "w-full text-dark-green hover:bg-brand-green/5 rounded-lg"
        : "text-dark-green hover:text-brand-green rounded-full hover:bg-white/50"
    }`}
    aria-expanded="false"
    aria-haspopup="true"
  >
    <div class="flex items-center gap-2">
      <Icon name="mdi:earth" class="w-5 h-5 text-brand-green" />
      <span class="current-language-label">{currentLabel}</span>
    </div>
    <Icon
      name="mdi:chevron-down"
      class="w-4 h-4 transition-transform duration-200 group-aria-expanded:rotate-180"
    />
  </button>

  <div
    class={`language-menu hidden absolute z-50 overflow-hidden glass-card rounded-2xl shadow-xl transition-all duration-200 ${
      mobile
        ? "bottom-full left-0 mb-1 w-full"
        : "right-0 mt-2 w-40 origin-top-right"
    }`}
    role="menu"
    aria-orientation="vertical"
  >
    <div class="p-2 flex flex-col gap-1">
      <a
        href={csPath}
        class="lang-option flex w-full items-center px-4 py-2.5 text-sm text-dark-green font-medium hover:bg-brand-green/10 hover:text-brand-green rounded-xl transition-all duration-200"
        role="menuitem"
      >
        Čeština
      </a>
      <a
        href={enPath}
        class="lang-option flex w-full items-center px-4 py-2.5 text-sm text-dark-green font-medium hover:bg-brand-green/10 hover:text-brand-green rounded-xl transition-all duration-200"
        role="menuitem"
      >
        English
      </a>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const containerElements = document.querySelectorAll(
      ".language-dropdown-container",
    );

    interface DropdownElements {
      container: HTMLElement;
      toggle: HTMLButtonElement | null;
      menu: HTMLElement | null;
    }

    // Cache DOM elements per container to avoid repeated querySelectors in global listeners
    const dropdowns: DropdownElements[] = [];
    for (let i = 0; i < containerElements.length; i++) {
      const container = containerElements[i] as HTMLElement;
      dropdowns.push({
        container,
        toggle: container.querySelector(
          ".language-toggle",
        ) as HTMLButtonElement | null,
        menu: container.querySelector(".language-menu") as HTMLElement | null,
      });
    }

    let activeDropdown: DropdownElements | null = null;

    // Close active menu when clicking outside
    document.addEventListener("click", (e) => {
      if (activeDropdown) {
        const { container, toggle, menu } = activeDropdown;
        if (toggle && menu && !container.contains(e.target as Node)) {
          toggle.setAttribute("aria-expanded", "false");
          menu.classList.add("hidden");
          toggle.classList.remove("group");
          activeDropdown = null;
        }
      }
    });

    // Setup each dropdown
    dropdowns.forEach((dropdown) => {
      const { container, toggle, menu } = dropdown;
      if (toggle && menu) {
        toggle.addEventListener("click", () => {
          const isExpanded = toggle.getAttribute("aria-expanded") === "true";

          // Close previously opened menu if it's different from the current one
          if (activeDropdown && activeDropdown !== dropdown) {
            const { toggle: activeToggle, menu: activeMenu } = activeDropdown;
            if (activeToggle && activeMenu) {
              activeToggle.setAttribute("aria-expanded", "false");
              activeMenu.classList.add("hidden");
              activeToggle.classList.remove("group");
            }
          }

          toggle.setAttribute("aria-expanded", String(!isExpanded));
          menu.classList.toggle("hidden");
          toggle.classList.toggle("group");

          if (!isExpanded) {
            activeDropdown = dropdown;
          } else {
            activeDropdown = null;
          }
        });
      }
    });
  });
</script>
