---
import { Icon } from 'astro-icon/components';

interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;
---

<div class={`relative language-dropdown-container ${mobile ? 'w-full' : 'inline-block'}`}>
  <button
    type="button"
    class={`language-toggle flex items-center justify-between gap-2 px-4 py-2 text-sm font-medium transition-colors ${
      mobile
        ? 'w-full text-dark-green hover:bg-brand-green/5 rounded-lg'
        : 'text-dark-green hover:text-brand-green rounded-full hover:bg-white/50'
    }`}
    aria-expanded="false"
    aria-haspopup="true"
  >
    <div class="flex items-center gap-2">
      <Icon name="mdi:earth" class="w-5 h-5 text-brand-green" />
      <span class="current-language-label">CS</span>
    </div>
    <Icon name="mdi:chevron-down" class="w-4 h-4 transition-transform duration-200 group-aria-expanded:rotate-180" />
  </button>

  <div
    class={`language-menu hidden absolute z-50 overflow-hidden bg-cream/90 backdrop-blur-md rounded-2xl shadow-xl border border-dark-green/10 transition-all duration-200 ${
      mobile
        ? 'relative w-full mt-1'
        : 'right-0 mt-2 w-40 origin-top-right'
    }`}
    role="menu"
    aria-orientation="vertical"
  >
    <div class="p-2 flex flex-col gap-1">
      <button
        type="button"
        class="lang-option flex w-full items-center px-4 py-2.5 text-sm text-dark-green font-medium hover:bg-brand-green/10 hover:text-brand-green rounded-xl transition-all duration-200"
        data-lang="cs-CZ"
        role="menuitem"
      >
        Čeština
      </button>
      <button
        type="button"
        class="lang-option flex w-full items-center px-4 py-2.5 text-sm text-dark-green font-medium hover:bg-brand-green/10 hover:text-brand-green rounded-xl transition-all duration-200"
        data-lang="en"
        role="menuitem"
      >
        English
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const containers = document.querySelectorAll('.language-dropdown-container');
    const dropdowns = Array.from(containers).map(container => ({
      container,
      toggle: container.querySelector('.language-toggle') as HTMLElement,
      menu: container.querySelector('.language-menu') as HTMLElement,
      options: container.querySelectorAll('.lang-option')
    }));

    let currentLang = localStorage.getItem('zvoleny-jazyk');
    if (!currentLang) {
      const browserLang = navigator.language.slice(0, 2);
      currentLang = browserLang === 'en' ? 'en' : 'cs-CZ';
      localStorage.setItem('zvoleny-jazyk', currentLang);
    }

    const labels = document.querySelectorAll('.current-language-label');
    for (const label of labels) {
      label.textContent = currentLang === 'en' ? 'EN' : 'CS';
    }

    const dropdownData = [];
    for (const container of containers) {
      const toggle = container.querySelector('.language-toggle');
      const menu = container.querySelector('.language-menu');
      const options = container.querySelectorAll('.lang-option');
      if (toggle && menu) {
        dropdownData.push({ container, toggle, menu, options });
      }
    }

    document.addEventListener('click', (e) => {
      for (const { container, toggle, menu } of dropdownData) {
        if (!container.contains(e.target as Node)) {
          toggle.setAttribute('aria-expanded', 'false');
          menu.classList.add('hidden');
          toggle.classList.remove('group');
        }
      }
    });

    for (const { container, toggle, menu, options } of dropdownData) {
      toggle.addEventListener('click', () => {
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true';

        for (const other of dropdownData) {
          if (other.container !== container) {
            other.toggle.setAttribute('aria-expanded', 'false');
            other.menu.classList.add('hidden');
            other.toggle.classList.remove('group');
          }
        }

        toggle.setAttribute('aria-expanded', String(!isExpanded));
        menu.classList.toggle('hidden');
        toggle.classList.toggle('group');
      });

      for (const option of options) {
        option.addEventListener('click', () => {
          const newLang = option.getAttribute('data-lang');
          if (newLang && newLang !== currentLang) {
            localStorage.setItem('zvoleny-jazyk', newLang);
            window.location.reload();
          } else {
            toggle.setAttribute('aria-expanded', 'false');
            menu.classList.add('hidden');
            toggle.classList.remove('group');
          }
        });
      }
    }
  });
</script>
