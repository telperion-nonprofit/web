---
import { useTranslations } from "../utils/i18n";
import type { Locale } from "../utils/i18n";
const lang = (Astro.currentLocale as Locale) || "cs";
const t = useTranslations(lang);
import { Icon } from "astro-icon/components";
---

<div
  id="donation-modal"
  class="fixed inset-0 z-[100] hidden"
  aria-labelledby="donation-modal-title"
  role="dialog"
  aria-modal="true"
  data-iban={t("donation_modal.iban")}
  data-qr-msg={t("donation_modal.qr_msg")}
>
  <div
    id="donation-modal-backdrop"
    class="fixed inset-0 bg-dark-green/60 backdrop-blur-sm transition-opacity opacity-0 duration-300"
  >
  </div>

  <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
    <div
      class="flex min-h-full items-center justify-center p-4 text-center sm:p-0"
    >
      <div
        id="donation-modal-panel"
        class="relative transform overflow-hidden rounded-3xl bg-cream text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-xl scale-95 opacity-0 duration-300"
      >
        <button
          type="button"
          id="close-donation-modal-btn"
          class="absolute right-6 top-6 text-dark-green/50 hover:text-brand-green transition-colors focus:outline-none rounded-full p-1 hover:bg-brand-green/10"
        >
          <span class="sr-only">{t("modal.close")}</span>
          <Icon name="mdi:close" class="h-6 w-6" />
        </button>

        <div class="px-6 pb-4 pt-8 sm:p-8 sm:pb-6">
          <div class="sm:flex sm:items-start">
            <div
              class="mx-auto flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-brand-green/10 sm:mx-0 sm:h-12 sm:w-12 border border-brand-green/20"
            >
              <Icon name="mdi:bank" class="h-6 w-6 text-brand-green" />
            </div>
            <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
              <h3
                class="text-2xl font-serif font-bold leading-6 text-brand-green"
                id="donation-modal-title"
              >
                {t("donation_modal.title")}
              </h3>
              <div class="mt-2">
                <p class="text-sm text-dark-green/80">
                  {t("donation_modal.description")}
                </p>
              </div>
            </div>
          </div>

          <div class="mt-6 flex flex-col md:flex-row gap-6">
            <div class="flex-1 space-y-4">
              <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
                <button
                  type="button"
                  class="amount-btn w-full rounded-xl bg-white px-3 py-2 text-sm font-semibold text-dark-green shadow-sm ring-1 ring-inset ring-dark-green/20 hover:bg-brand-green/5 focus:outline-none focus:ring-2 focus:ring-brand-green data-[active=true]:bg-brand-green data-[active=true]:text-white data-[active=true]:ring-brand-green"
                  data-amount="100"
                >
                  100 Kč
                </button>
                <button
                  type="button"
                  class="amount-btn w-full rounded-xl bg-white px-3 py-2 text-sm font-semibold text-dark-green shadow-sm ring-1 ring-inset ring-dark-green/20 hover:bg-brand-green/5 focus:outline-none focus:ring-2 focus:ring-brand-green data-[active=true]:bg-brand-green data-[active=true]:text-white data-[active=true]:ring-brand-green"
                  data-amount="200"
                >
                  200 Kč
                </button>
                <button
                  type="button"
                  class="amount-btn w-full rounded-xl bg-white px-3 py-2 text-sm font-semibold text-dark-green shadow-sm ring-1 ring-inset ring-dark-green/20 hover:bg-brand-green/5 focus:outline-none focus:ring-2 focus:ring-brand-green data-[active=true]:bg-brand-green data-[active=true]:text-white data-[active=true]:ring-brand-green"
                  data-amount="500"
                >
                  500 Kč
                </button>
                <button
                  type="button"
                  class="amount-btn w-full rounded-xl bg-white px-3 py-2 text-sm font-semibold text-dark-green shadow-sm ring-1 ring-inset ring-dark-green/20 hover:bg-brand-green/5 focus:outline-none focus:ring-2 focus:ring-brand-green data-[active=true]:bg-brand-green data-[active=true]:text-white data-[active=true]:ring-brand-green"
                  data-amount="1000"
                >
                  1000 Kč
                </button>
                <button
                  type="button"
                  class="amount-btn w-full rounded-xl bg-white px-3 py-2 text-sm font-semibold text-dark-green shadow-sm ring-1 ring-inset ring-dark-green/20 hover:bg-brand-green/5 focus:outline-none focus:ring-2 focus:ring-brand-green data-[active=true]:bg-brand-green data-[active=true]:text-white data-[active=true]:ring-brand-green sm:col-span-2"
                  data-amount="other"
                >
                  {t("donation_modal.amount_other")}
                </button>
              </div>

              <div id="custom-amount-container" class="hidden">
                <div class="relative rounded-md shadow-sm">
                  <input
                    type="number"
                    id="custom-amount-input"
                    class="block w-full rounded-xl border-0 py-2.5 pl-4 pr-12 text-dark-green ring-1 ring-inset ring-dark-green/20 placeholder:text-dark-green/40 focus:ring-2 focus:ring-inset focus:ring-brand-green sm:text-sm sm:leading-6 bg-white"
                    placeholder="0"
                    min="1"
                  />
                  <div
                    class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4"
                  >
                    <span class="text-dark-green/60 sm:text-sm font-medium"
                      >Kč</span
                    >
                  </div>
                </div>
              </div>

              <div
                class="rounded-2xl border border-brand-green/10 bg-white/50 p-4 text-center"
              >
                <p
                  class="mb-1 text-xs font-bold uppercase tracking-wider text-dark-green/60"
                >
                  {t("donation_modal.account_number")}
                </p>
                <div
                  class="text-xl font-bold tracking-wide text-brand-green break-all"
                  id="account-number-display"
                >
                  2102801318/2010
                </div>
                <button
                  type="button"
                  id="copy-account-btn"
                  class="mt-2 inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm font-medium text-brand-green hover:bg-brand-green/10 transition-colors"
                >
                  <span class="copy-btn-default flex items-center gap-1.5">
                    <Icon name="mdi:content-copy" class="h-4 w-4" />
                    {t("donation_modal.copy_account")}
                  </span>
                  <span class="copy-btn-success hidden items-center gap-1.5">
                    <Icon name="mdi:check" class="h-4 w-4" />
                    {t("donation_modal.copied")}
                  </span>
                </button>
              </div>
            </div>

            <div class="flex flex-col items-center justify-center shrink-0">
              <div
                class="rounded-2xl bg-white p-4 shadow-sm border-2 border-brand-green"
              >
                <img
                  id="qr-code-img"
                  src=""
                  alt="QR Platba"
                  class="h-48 w-48 object-contain"
                />
              </div>
            </div>
          </div>

          <div class="mt-4 text-center text-sm text-dark-green/70">
            <a
              href="https://ib.fio.cz/ib/transparent?a=2102801318"
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-green hover:underline"
            >
              {t("donation_modal.transparent_account_link")}
            </a>
          </div>
        </div>
        <div
          class="bg-brand-green/5 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6 border-t border-brand-green/10"
        >
          <button
            type="button"
            id="close-donation-modal-confirm"
            class="mt-3 inline-flex w-full justify-center rounded-full bg-white px-6 py-2.5 text-sm font-bold text-dark-green shadow-sm ring-1 ring-inset ring-dark-green/20 hover:bg-gray-50 sm:mt-0 sm:w-auto"
          >
            {t("modal.button.cancel")}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  let generateQRDataURILazy:
    | ((options: {
        iban: string;
        amount?: number;
        message?: string;
      }) => Promise<string>)
    | null = null;

  const getGenerateQRDataURI = async () => {
    if (generateQRDataURILazy) return generateQRDataURILazy;
    const mod = await import("../utils/qr");
    generateQRDataURILazy = mod.generateQRDataURI;
    return generateQRDataURILazy;
  };

  document.addEventListener("astro:page-load", () => {
    setupModal();
  });

  document.addEventListener("DOMContentLoaded", () => {
    // Check if not handled by astro:page-load (first load without view transitions)
    setupModal();
  });

  function setupModal() {
    const modal = document.getElementById("donation-modal");
    const backdrop = document.getElementById("donation-modal-backdrop");
    const panel = document.getElementById("donation-modal-panel");
    const closeBtn = document.getElementById("close-donation-modal-btn");
    const cancelBtn = document.getElementById("close-donation-modal-confirm");

    const amountBtns = document.querySelectorAll(".amount-btn");
    const customAmountContainer = document.getElementById(
      "custom-amount-container",
    );
    const customAmountInput = document.getElementById(
      "custom-amount-input",
    ) as HTMLInputElement;
    const qrCodeImg = document.getElementById(
      "qr-code-img",
    ) as HTMLImageElement;
    const copyAccountBtn = document.getElementById("copy-account-btn");
    const accountNumberDisplay = document.getElementById(
      "account-number-display",
    );

    if (!modal || !backdrop || !panel) return;

    // The static info
    const iban = modal.getAttribute("data-iban") || "";
    const qrMessage = modal.getAttribute("data-qr-msg") || "";
    const accountNumber = "2102801318/2010"; // Domestic

    let currentAmount: number | undefined = undefined;

    const renderQR = async () => {
      const generateQRDataURI = await getGenerateQRDataURI();
      const dataUri = await generateQRDataURI({
        iban,
        amount: currentAmount,
        message: qrMessage,
      });
      if (qrCodeImg && dataUri) {
        qrCodeImg.src = dataUri;
      }
    };

    const handleAmountSelection = (btn: Element) => {
      // Clear all active states
      amountBtns.forEach((b) => b.setAttribute("data-active", "false"));
      btn.setAttribute("data-active", "true");

      const amountVal = btn.getAttribute("data-amount");

      if (amountVal === "other") {
        customAmountContainer?.classList.remove("hidden");
        currentAmount = customAmountInput?.value
          ? parseFloat(customAmountInput.value)
          : undefined;
      } else {
        customAmountContainer?.classList.add("hidden");
        currentAmount = parseFloat(amountVal || "0");
      }

      if (debounceTimer) {
        clearTimeout(debounceTimer);
        debounceTimer = null;
      }
      renderQR();
    };

    amountBtns.forEach((btn) => {
      btn.addEventListener("click", () => handleAmountSelection(btn));
    });

    let debounceTimer: ReturnType<typeof setTimeout> | null = null;
    customAmountInput?.addEventListener("input", () => {
      const val = parseFloat(customAmountInput.value);
      currentAmount = isNaN(val) || val <= 0 ? undefined : val;
      if (debounceTimer) {
        clearTimeout(debounceTimer);
      }
      debounceTimer = setTimeout(() => {
        renderQR();
      }, 300);
    });

    const copyBtnDefault = copyAccountBtn?.querySelector(".copy-btn-default");
    const copyBtnSuccess = copyAccountBtn?.querySelector(".copy-btn-success");

    copyAccountBtn?.addEventListener("click", () => {
      navigator.clipboard.writeText(accountNumber).then(() => {
        if (copyBtnDefault && copyBtnSuccess) {
          copyBtnDefault.classList.add("hidden");
          copyBtnSuccess.classList.remove("hidden");
          copyBtnSuccess.classList.add("flex");

          setTimeout(() => {
            copyBtnSuccess.classList.add("hidden");
            copyBtnSuccess.classList.remove("flex");
            copyBtnDefault.classList.remove("hidden");
          }, 2000);
        }
      });
    });

    const openModal = () => {
      modal.classList.remove("hidden");
      // Use setTimeout to allow display:block to apply before changing opacity
      setTimeout(() => {
        backdrop.classList.remove("opacity-0");
        panel.classList.remove("scale-95", "opacity-0");
        panel.classList.add("scale-100", "opacity-100");
      }, 10);
      document.body.style.overflow = "hidden";

      // Initial QR render without amount
      renderQR();
    };

    const closeModal = () => {
      backdrop.classList.add("opacity-0");
      panel.classList.remove("scale-100", "opacity-100");
      panel.classList.add("scale-95", "opacity-0");

      setTimeout(() => {
        modal.classList.add("hidden");
      }, 300);
      document.body.style.overflow = "";

      if (debounceTimer) {
        clearTimeout(debounceTimer);
        debounceTimer = null;
      }

      // Reset UI state
      amountBtns.forEach((b) => b.setAttribute("data-active", "false"));
      customAmountContainer?.classList.add("hidden");
      if (customAmountInput) customAmountInput.value = "";
      currentAmount = undefined;
    };

    // Listen for custom event
    document.removeEventListener("open-donation-modal", openModal);
    document.addEventListener("open-donation-modal", openModal);

    closeBtn?.addEventListener("click", closeModal);
    cancelBtn?.addEventListener("click", closeModal);

    // Close on click outside
    modal.addEventListener("click", (e) => {
      if (e.target === modal.querySelector(".min-h-full")) {
        closeModal();
      }
    });

    // Close on escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        closeModal();
      }
    });
  }
</script>
