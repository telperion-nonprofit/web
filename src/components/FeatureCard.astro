---
import { Icon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  title: string;
  icon: string;
}

const { title, icon, class: className, ...attrs } = Astro.props;
---

<!-- 
  PŘIDÁNO: transform-gpu a will-change-transform.
  Tohle je ten kouzelný lék na problikávání glassmorphismu na Vercelu/v Chrome!
-->
<div class:list={["glass-card rounded-3xl p-6 sm:p-8 transform-gpu will-change-transform h-full flex flex-col items-start transition-transform duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-green/10", className]} {...attrs}>
  
  <div class="w-14 h-14 rounded-2xl bg-brand-green/10 flex items-center justify-center text-brand-green mb-6 border border-brand-green/20">
    <Icon name={icon} class="w-7 h-7" />
  </div>

  <h3 class="text-xl md:text-2xl font-serif font-bold text-brand-green mb-4">
    {title}
  </h3>

  <p class="text-dark-green/80 font-medium leading-relaxed">
    <slot />
  </p>

</div>