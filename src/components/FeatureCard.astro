---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  icon: string;
}

const { title, icon } = Astro.props;
---

<!-- 
  Aplikace velmi jemného Glassmorphism efektu na kartu:
  - glass-card: Sjednocený Glassmorphism efekt (krytí, rozmazání, rámeček)
  - shadow-lg: Stín pro oddělení od pozadí
-->
<div class="glass-card rounded-3xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
  
  <!-- Jemný barevný akcent při najetí myší (volitelné, vypadá to skvěle) -->
  <div class="absolute top-0 left-0 w-full h-1 bg-brand-green/50 transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300"></div>

  <div class="w-16 h-16 bg-white/50 rounded-2xl flex items-center justify-center mb-6 text-brand-green border border-white/50">
    <Icon name={icon} class="w-8 h-8" />
  </div>
  
  <h3 class="text-2xl font-serif font-bold text-brand-green mb-4 relative z-10">
    {title}
  </h3>
  
  <p class="text-dark-green leading-relaxed relative z-10 font-medium">
    <slot />
  </p>
</div>