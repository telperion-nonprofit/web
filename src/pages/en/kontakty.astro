---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import SectionBadge from "../../components/SectionBadge.astro";
import jakubNekvasilPhoto from "../../assets/team/jakub_nekvasil.jpg";
import damiaVeselaPhoto from "../../assets/team/damia_vesela.jpg";
import martinJirkuPhoto from "../../assets/team/martin_jirku.jpg";
import magdalenaKlimovaPhoto from "../../assets/team/magdalena_klimova.jpg";
import lucieKubasovaPhoto from "../../assets/team/lucie_kubasova.jpg";
import jolanaBalcarovaPhoto from "../../assets/team/jolana_balcarova.jpg";

const teamMembers = [
  {
    name: "Jakub Nekvasil",
    role: "President, Re:generation Program, Climate Fresk Community Coordination for CZ, Facilitator",
    email: "jakub.nekvasil@telperion.cz",
    phone: "+420 776 059 998",
    image: jakubNekvasilPhoto,
  },
  {
    name: "Damia Veselá",
    role: "Vice President, Administration, Climate Weekend for Scouts Program",
    email: "damia.vesela@telperion.cz",
    phone: "+420 608 168 078",
    image: damiaVeselaPhoto,
  },
  {
    name: "Anna Zezulka",
    role: "Web Developer, Graphic Designer",
    email: "anna.zezulka@telperion.cz",
    phone: "",
    image: null,
  },
  {
    name: "Martin Jirků",
    role: "Internal Operations, Communication, Partnerships",
    email: "martin.jirku@telperion.cz",
    phone: "+420 734 465 698",
    image: martinJirkuPhoto,
  },
  {
    name: "Magdaléna Klímová",
    role: "Climate Days Program Coordinator",
    email: "magdalena.klimova@telperion.cz",
    phone: "",
    image: magdalenaKlimovaPhoto,
  },
  {
    name: "Lucie Kubášová",
    role: "Climate Fresk Coordinator",
    email: "lucie.kubasova@telperion.cz",
    phone: "+420 792 474 847",
    image: lucieKubasovaPhoto,
  },
  {
    name: "Klára Adámková",
    role: "Program Facilitation (Climate Fresk)",
    email: "klara.adamkova@telperion.cz",
    phone: "+420 734 695 714",
    image: null,
  },
  {
    name: "Valeriia Tsyhanchuk",
    role: "",
    email: "valeriia.tsyhanchuk@telperion.cz",
    phone: "+420 723 394 013",
    image: null,
  },
  {
    name: "Jolana Balcarová",
    role: "Climate Days Instructor, Graphics, Board Game Development",
    email: "jolana.balcarova@telperion.cz",
    phone: "",
    image: jolanaBalcarovaPhoto,
  },
  {
    name: "Sofia Grycová",
    role: "Graphics, Climate Days Instructor",
    email: "sofia.grycova@telperion.cz",
    phone: "",
    image: null,
  },
  {
    name: "David Bartoš",
    role: "Climate Days Instructor, Climate Fresk Facilitator",
    email: "david.bartos@telperion.cz",
    phone: "",
    image: null,
  },
];
---

<Layout title="Our Team and Contacts">
  <section
    class="relative pt-12 pb-8 md:pt-16 md:pb-8 overflow-hidden text-center"
  >
    <div class="container mx-auto px-4 max-w-4xl">
      <SectionBadge> Our Team </SectionBadge>
      <h1
        class="text-4xl md:text-6xl font-serif font-bold text-brand-green mb-6"
      >
        Who is <span class="italic">behind</span> the association?
      </h1>
      <p
        class="text-lg md:text-xl text-dark-green mb-8 leading-relaxed max-w-2xl mx-auto font-medium"
      >
        We are a group of students who want to change the way we talk about
        climate. Meet us!
      </p>

      <div class="mb-4">
        <a
          href="mailto:info@telperion.cz"
          class="inline-flex items-center gap-3 text-brand-green font-bold text-xl hover:text-dark-green transition-all bg-white/50 backdrop-blur-sm px-8 py-3 rounded-full border border-brand-green/20 hover:bg-white/80 hover:shadow-lg hover:-translate-y-0.5"
        >
          <Icon name="mdi:email-outline" class="w-6 h-6" />
          info@telperion.cz
        </a>
      </div>
    </div>
  </section>

  <section class="pb-8 md:pb-8">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          teamMembers.map((member) => (
            <div class="glass-card rounded-3xl p-6 sm:p-8 transform-gpu will-change-transform h-full flex flex-col transition-transform duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-green/10">
              <div class="w-24 h-24 rounded-full bg-brand-green/10 flex items-center justify-center text-brand-green mb-6 mx-auto overflow-hidden border-2 border-brand-green/20">
                {member.image ? (
                  <Image
                    src={member.image}
                    alt={member.name}
                    class="w-full h-full object-cover"
                    width={96}
                    height={96}
                    quality={60}
                  />
                ) : (
                  <span class="text-3xl font-serif font-bold">
                    {member.name.charAt(0)}
                  </span>
                )}
              </div>

              <div class="text-center mb-4">
                <h3 class="text-2xl font-serif font-bold text-brand-green mb-1">
                  {member.name}
                </h3>
                <p class="text-sm font-bold text-dark-green/60 uppercase tracking-wider">
                  {member.role}
                </p>
              </div>

              <div class="flex flex-col gap-2 mt-auto">
                {member.email && (
                  <a
                    href={`mailto:${member.email}`}
                    class="flex items-center gap-3 text-sm text-dark-green font-medium hover:text-brand-green transition-colors p-2 rounded-xl hover:bg-white/40"
                  >
                    <Icon
                      name="mdi:email-outline"
                      class="w-5 h-5 text-brand-green flex-shrink-0"
                    />
                    <span class="truncate">{member.email}</span>
                  </a>
                )}
                {member.phone && (
                  <a
                    href={`tel:${member.phone.replace(/\s+/g, "")}`}
                    class="flex items-center gap-3 text-sm text-dark-green font-medium hover:text-brand-green transition-colors p-2 rounded-xl hover:bg-white/40"
                  >
                    <Icon
                      name="mdi:phone-outline"
                      class="w-5 h-5 text-brand-green flex-shrink-0"
                    />
                    <span>{member.phone}</span>
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-16 md:mt-24 max-w-4xl mx-auto">
        <div
          class="glass-card rounded-3xl p-8 sm:p-12 text-center md:text-left border border-brand-green/20"
        >
          <h2
            class="text-3xl font-serif font-bold text-brand-green mb-8 text-center"
          >
            Association Details
          </h2>

          <div class="grid md:grid-cols-3 gap-8">
            <div class="flex flex-col items-center md:items-start">
              <div
                class="w-12 h-12 rounded-xl bg-brand-green/10 flex items-center justify-center text-brand-green mb-4 border border-brand-green/20"
              >
                <Icon name="mdi:office-building-marker" class="w-6 h-6" />
              </div>
              <h3 class="text-lg font-bold text-brand-green mb-2">
                Headquarters
              </h3>
              <p class="text-dark-green/80 text-sm font-medium">
                Úvozová 261/6, 252 62
              </p>
            </div>

            <div class="flex flex-col items-center md:items-start">
              <div
                class="w-12 h-12 rounded-xl bg-brand-green/10 flex items-center justify-center text-brand-green mb-4 border border-brand-green/20"
              >
                <Icon name="mdi:identifier" class="w-6 h-6" />
              </div>
              <h3 class="text-lg font-bold text-brand-green mb-2">ID Number</h3>
              <p class="text-dark-green/80 text-sm font-medium">21104271</p>
            </div>

            <div class="flex flex-col items-center md:items-start">
              <div
                class="w-12 h-12 rounded-xl bg-brand-green/10 flex items-center justify-center text-brand-green mb-4 border border-brand-green/20"
              >
                <Icon name="mdi:bank-outline" class="w-6 h-6" />
              </div>
              <h3 class="text-lg font-bold text-brand-green mb-2">
                Transparent Account
              </h3>
              <p class="text-dark-green/80 text-sm font-medium break-all">
                2102801318 / 2010
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
