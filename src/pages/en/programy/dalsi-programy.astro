---
import { useTranslations, replacePlaceholders } from "../../../utils/i18n";
import type { Locale } from "../../../utils/i18n";
const lang = (Astro.currentLocale as Locale) || "cs";
const t = useTranslations(lang);
import Layout from "../../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title={t("other.page_title")}>
  <section class="pt-12 pb-8 text-center px-4 max-w-3xl mx-auto">
    <span
      class="inline-block py-1 px-3 rounded-full bg-brand-green/10 text-brand-green text-sm font-bold mb-4 tracking-wide"
    >
      {t("other.badge")}
    </span>
    <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-green mb-6">
      {t("other.title_main")}
      <span class="italic">{t("other.title_highlight")}</span>
    </h1>
    <p class="text-lg text-dark-green/80 font-medium">{t("other.subtitle")}</p>
  </section>

  <div class="container mx-auto max-w-4xl px-4 pb-8">
    <div
      class="glass-card rounded-3xl p-8 relative overflow-hidden transform-gpu will-change-transform transition-transform hover:-translate-y-1"
    >
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <div
          class="w-16 h-16 shrink-0 bg-brand-green/10 rounded-2xl flex items-center justify-center text-brand-green border border-brand-green/20"
        >
          <Icon name="mdi:tshirt-crew-outline" class="w-8 h-8" />
        </div>

        <div class="flex-grow">
          <h3 class="text-2xl font-serif font-bold text-brand-green mb-2">
            {t("other.fashion.title")}
          </h3>
          <p
            class="text-sm font-bold text-dark-green/50 mb-4 uppercase tracking-wide"
          >
            {t("other.fashion.authors")}
          </p>

          <div
            class="bg-white/50 rounded-xl p-4 mb-4 border border-white inline-block"
          >
            <p
              class="text-sm text-dark-green/80 font-medium flex items-center gap-2"
            >
              <Icon name="mdi:hammer-wrench" class="w-5 h-5 text-brand-green" />
              {t("other.fashion.status")}
            </p>
          </div>

          <p class="text-dark-green/80 text-sm leading-relaxed">
            {t("other.fashion.description")}
          </p>
        </div>
      </div>
    </div>

    <div
      class="glass-card rounded-3xl p-8 mt-8 relative overflow-hidden transform-gpu will-change-transform transition-transform hover:-translate-y-1"
    >
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <div
          class="w-16 h-16 shrink-0 bg-brand-green/10 rounded-2xl flex items-center justify-center text-brand-green border border-brand-green/20"
        >
          <Icon name="mdi:cube-outline" class="w-8 h-8" />
        </div>

        <div class="flex-grow">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-2xl font-serif font-bold text-brand-green">
              {t("other.klima.title")}
            </h3>
            <span
              class="bg-brand-green text-white text-[10px] font-bold uppercase px-3 py-1 rounded-full animate-pulse"
            >
              {t("other.klima.badge")}
            </span>
          </div>
          <p
            class="text-sm font-bold text-dark-green/50 mb-4 uppercase tracking-wide"
          >
            {t("other.klima.author")}
          </p>

          <div
            class="bg-white/50 rounded-xl p-4 mb-4 border border-white inline-block"
          >
            <p
              class="text-sm text-dark-green/80 font-medium flex items-center gap-2"
            >
              <Icon
                name="mdi:calendar-clock"
                class="w-5 h-5 text-brand-green"
              />
              {t("other.klima.status")}
            </p>
          </div>

          <p class="text-dark-green/80 text-sm leading-relaxed">
            {t("other.klima.description")}
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
