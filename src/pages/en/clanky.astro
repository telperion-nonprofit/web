---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SectionBadge from "../../components/SectionBadge.astro";
import { Icon } from "astro-icon/components";

const allArticles = await getCollection("clanky");

const sortedArticles = allArticles
  .filter((article) => article.data.pubDate)
  .map((article) => ({
    article,
    time: article.data.pubDate!.getTime(),
  }))
  .sort((a, b) => b.time - a.time)
  .map(({ article }) => article);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}
---

<Layout title="Articles and Knowledge Base">
  <section class="pt-12 pb-8 md:pt-16 md:pb-8">
    <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-6xl">
      <div class="text-center mb-16 max-w-3xl mx-auto">
        <SectionBadge> Our Knowledge Base </SectionBadge>
        <h1
          class="text-4xl md:text-5xl font-serif font-bold text-brand-green mb-6"
        >
          Articles <span class="italic">and Analysis</span>
        </h1>
        <p class="text-dark-green text-lg font-medium leading-relaxed">
          Read our texts on climate change, environment, and society.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        {
          sortedArticles.map((article) => (
            <a
              href={`/en/clanky/${article.id.replace(/\.md$/, "")}`}
              class="glass-card rounded-3xl p-6 sm:p-8 transform-gpu will-change-transform flex flex-col group transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-green/10 border border-brand-green/10 h-full"
            >
              <div class="flex items-center gap-3 text-sm text-dark-green/60 font-medium mb-4">
                <div class="flex items-center gap-1.5 bg-cream/50 px-3 py-1 rounded-full border border-dark-green/10">
                  <Icon name="mdi:calendar" class="w-4 h-4 text-brand-green" />
                  <time datetime={article.data.pubDate!.toISOString()}>
                    {formatDate(article.data.pubDate!)}
                  </time>
                </div>
              </div>

              <h2 class="text-2xl font-serif font-bold text-brand-green mb-3 group-hover:text-dark-green transition-colors line-clamp-2">
                {article.data.title}
              </h2>

              <p class="text-dark-green/80 text-base leading-relaxed mb-6 flex-grow line-clamp-3">
                {article.data.description}
              </p>

              <div class="mt-auto pt-6 border-t border-brand-green/10 flex items-center justify-between">
                <div class="flex items-center gap-2 text-sm text-dark-green font-medium">
                  <div class="w-8 h-8 rounded-full bg-brand-green/10 flex items-center justify-center text-brand-green font-bold font-serif text-sm">
                    {article.data.author.charAt(0)}
                  </div>
                  <span>{article.data.author}</span>
                </div>

                <div class="w-8 h-8 rounded-full bg-brand-green text-cream flex items-center justify-center group-hover:scale-110 group-hover:bg-dark-green transition-all shadow-md">
                  <Icon name="mdi:arrow-right" class="w-4 h-4" />
                </div>
              </div>
            </a>
          ))
        }
      </div>

      {
        sortedArticles.length === 0 && (
          <div class="text-center py-20 bg-cream/50 rounded-3xl border border-dark-green/10">
            <Icon
              name="mdi:text-box-search-outline"
              class="w-16 h-16 text-brand-green/40 mx-auto mb-4"
            />
            <p class="text-xl text-dark-green/60 font-serif italic">
              No articles are currently published.
            </p>
          </div>
        )
      }
    </div>
  </section>
</Layout>
