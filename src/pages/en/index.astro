            {t("home.reviews.1.text")}
          </p>
          <div class="mt-auto pt-6 border-t border-brand-green/10">
            <h3 class="font-bold text-dark-green text-lg">
              {t("home.reviews.1.author")}
            </h3>
            <span class="text-sm text-dark-green/80 font-medium"
              >{t("home.reviews.1.date")}</span
            >
          </div>
        </div>

        <!-- Recenze 2 -->
        <div
          class="glass-card rounded-3xl p-8 flex flex-col shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-brand-green/20 relative"
        >
          <svg
            class="absolute top-6 right-8 w-10 h-10 text-brand-green/10"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
            ></path>
          </svg>
          <p
            class="text-dark-green font-medium leading-relaxed italic mb-8 grow relative z-10"
          >
            {t("home.reviews.2.text")}
          </p>
          <div class="mt-auto pt-6 border-t border-brand-green/10">
            <h3 class="font-bold text-dark-green text-lg">
              {t("home.reviews.2.author")}
            </h3>
            <span class="text-sm text-dark-green/80 font-medium"
              >{t("home.reviews.2.date")}</span
            >
          </div>
        </div>

        <!-- Recenze 3 -->
        <div
          class="glass-card rounded-3xl p-8 flex flex-col shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-brand-green/20 relative"
        >
          <svg
            class="absolute top-6 right-8 w-10 h-10 text-brand-green/10"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
            ></path>
          </svg>
          <p
            class="text-dark-green font-medium leading-relaxed italic mb-8 grow relative z-10"
          >
            {t("home.reviews.3.text")}
          </p>
          <div class="mt-auto pt-6 border-t border-brand-green/10">
            <h3 class="font-bold text-dark-green text-lg">
              {t("home.reviews.3.author")}
            </h3>
            <span class="text-sm text-dark-green/80 font-medium"
              >{t("home.reviews.3.date")}</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<!-- SEKCE: EVENT MODAL -->
<div
  id="climate-fresk-modal"
  class="fixed inset-0 z-150 hidden items-center justify-center p-4 sm:p-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="climate-fresk-title"
>
  <div
    id="climate-fresk-backdrop"
    class="absolute inset-0 bg-dark-green/70 backdrop-blur-sm transition-opacity duration-300 opacity-0"
  >
  </div>
  <div
    id="climate-fresk-content"
    class="relative z-10 w-full max-w-2xl bg-cream rounded-3xl shadow-2xl p-6 sm:p-10 max-h-[90vh] overflow-y-auto transition-all duration-300 scale-95 opacity-0"
  >
    <button
      type="button"
      id="climate-fresk-close"
      class="absolute top-4 right-4 text-dark-green/50 hover:text-brand-green transition-colors p-2 rounded-full hover:bg-brand-green/10"
      aria-label="Zavřít"
    >
      <Icon name="mdi:close" class="w-6 h-6" />
    </button>
    <h3
      id="climate-fresk-title"
      class="text-2xl md:text-3xl font-serif font-bold text-brand-green mb-4 pr-8"
    >
      {t("home.fresk_modal.title")}
    </h3>
    <div
      class="flex flex-wrap gap-4 mb-6 text-sm font-medium text-dark-green/80"
    >
      <div class="flex items-center gap-1.5">
        <Icon name="mdi:calendar" class="w-5 h-5" />
        {t("home.fresk_modal.date")}
      </div>
      <div class="flex items-center gap-1.5">
        <Icon name="mdi:clock-outline" class="w-5 h-5" />
        {t("home.fresk_modal.time")}
      </div>
      <div class="flex items-center gap-1.5">
        <Icon name="mdi:map-marker" class="w-5 h-5" />
        {t("home.fresk_modal.location")}
      </div>
      <div class="flex items-center gap-1.5">
        <Icon name="mdi:ticket-outline" class="w-5 h-5" />
        {t("home.fresk_modal.price")}
      </div>
    </div>

    <div class="space-y-4 text-dark-green font-medium">
      <p>
        <strong>{t("home.fresk_modal.p1_strong")}</strong>
        {t("home.fresk_modal.p1_rest")}
      </p>
      <p>{t("home.fresk_modal.p2")}</p>
      <ul class="list-disc pl-5 space-y-1">
        <li>{t("home.fresk_modal.li1")}</li>
        <li>{t("home.fresk_modal.li2")}</li>
        <li>{t("home.fresk_modal.li3")}</li>
        <li>{t("home.fresk_modal.li4")}</li>
      </ul>
      <p class="text-sm text-dark-green/70 mt-4">
        ✅ <strong>{t("home.fresk_modal.p3_strong")}</strong>{
          t("home.fresk_modal.p3_rest")
        }
      </p>
    </div>

    <div
      class="mt-8 flex flex-col sm:flex-row gap-4 justify-center sm:justify-start"
    >
      <a
        href="https://association.climatefresk.org/training_sessions/a78d82d9-32bf-409b-a988-e0c72832d421/show_public?language=en&tenant_token=36bd2274d3982262c0021755"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block w-full sm:w-auto bg-brand-green text-white px-8 py-3 rounded-full font-bold text-lg hover:bg-dark-green transition shadow-lg shadow-brand-green/20 text-center"
      >
        {t("home.fresk_modal.btn_register")}
      </a>
      <button
        type="button"
        id="climate-fresk-action-close"
        class="inline-block w-full sm:w-auto bg-brand-green/20 text-dark-green px-8 py-3 rounded-full font-bold text-lg hover:bg-brand-green/30 transition focus:outline-none"
      >
        {t("home.fresk_modal.btn_close")}
      </button>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    // Event date is April 9, 2026. Setting cutoff to midnight April 10, 2026 for automatic hiding.
    const eventDate = new Date("2026-04-10T00:00:00+02:00");
    const now = new Date();

    if (now < eventDate && !sessionStorage.getItem("climateFreskModalSeen")) {
      const modal = document.getElementById("climate-fresk-modal");
      const backdrop = document.getElementById("climate-fresk-backdrop");
      const content = document.getElementById("climate-fresk-content");
      const closeBtn = document.getElementById("climate-fresk-close");
      const actionCloseBtn = document.getElementById(
        "climate-fresk-action-close",
      );

      if (modal && backdrop && content) {
        modal.classList.remove("hidden");
        modal.classList.add("flex");

        setTimeout(() => {
          backdrop.classList.remove("opacity-0");
          backdrop.classList.add("opacity-100");
          content.classList.remove("scale-95", "opacity-0");
          content.classList.add("scale-100", "opacity-100");
        }, 10);

        const closeModal = () => {
          backdrop.classList.remove("opacity-100");
          backdrop.classList.add("opacity-0");
          content.classList.remove("scale-100", "opacity-100");
          content.classList.add("scale-95", "opacity-0");

          setTimeout(() => {
            modal.classList.add("hidden");
            modal.classList.remove("flex");
          }, 300);

          sessionStorage.setItem("climateFreskModalSeen", "true");
        };

        closeBtn?.addEventListener("click", closeModal);
        actionCloseBtn?.addEventListener("click", closeModal);
        backdrop?.addEventListener("click", closeModal);
      }
    }
  });
</script>

<div
  id="photo-lightbox"
  class="fixed inset-0 z-200 hidden items-center justify-center p-6 sm:p-10 md:p-16"
  role="dialog"
  aria-modal="true"
  aria-label="Photo lightbox"
>
  <div
    id="lightbox-backdrop"
    class="absolute inset-0 bg-dark-green/70 backdrop-blur-sm transition-opacity duration-300 opacity-0"
  >
  </div>
  <img
    id="lightbox-img"
    src=""
    alt=""
    class="relative z-10 max-w-full max-h-full rounded-3xl shadow-2xl object-contain transition-all duration-300 scale-95 opacity-0"
  />
  <button
    type="button"
    id="lightbox-close"
    class="absolute top-4 right-4 z-20 text-cream/80 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
    aria-label="Close"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>

<script>
  import { getSafeLanguage } from "../../utils/lang";

  const iframe = document.getElementById("umap-iframe") as HTMLIFrameElement;
  if (iframe) {
    const lang = getSafeLanguage();
    const umapLang = lang === "en" ? "en" : "cs-cz";
    const dataSrc = iframe.getAttribute("data-src") || "";
    const newSrc = dataSrc.replace(
      /openstreetmap\.fr\/[a-z-]+\/map/,
      `openstreetmap.fr/${umapLang}/map`,
    );

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            iframe.src = newSrc;
            iframe.onload = () => {
              iframe.classList.remove("opacity-0");
            };
            observer.disconnect();
          }
        });
      },
      { rootMargin: "200px 0px" },
    );

    observer.observe(iframe);
  }

  const lightbox = document.getElementById("photo-lightbox") as HTMLDivElement;
  const lightboxImg = document.getElementById(
    "lightbox-img",
  ) as HTMLImageElement;
  const lightboxBackdrop = document.getElementById(
    "lightbox-backdrop",
  ) as HTMLDivElement;
  const lightboxClose = document.getElementById(
    "lightbox-close",
  ) as HTMLButtonElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    requestAnimationFrame(() => {
      lightboxBackdrop.classList.remove("opacity-0");
      lightboxBackdrop.classList.add("opacity-100");
      lightboxImg.classList.remove("scale-95", "opacity-0");
      lightboxImg.classList.add("scale-100", "opacity-100");
    });
  }

  function closeLightbox() {
    lightboxBackdrop.classList.remove("opacity-100");
    lightboxBackdrop.classList.add("opacity-0");
    lightboxImg.classList.remove("scale-100", "opacity-100");
    lightboxImg.classList.add("scale-95", "opacity-0");
    setTimeout(() => {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightboxImg.src = "";
    }, 300);
  }

  document.querySelectorAll(".lightbox-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = (btn as HTMLElement).dataset.fullSrc || "";
      const alt = btn.querySelector("img")?.alt || "";
      openLightbox(src, alt);
    });
  });

  lightboxClose.addEventListener("click", closeLightbox);
  lightboxBackdrop.addEventListener("click", closeLightbox);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !lightbox.classList.contains("hidden")) {
      closeLightbox();
    }
  });
</script>
