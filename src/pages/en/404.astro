---
import Layout from "../../layouts/Layout.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
const lang = "en";
---

<Layout title="Page Not Found (404)">
  <section class="flex-grow flex flex-col items-center justify-center w-full">
    <div class="container mx-auto px-4 text-center max-w-2xl">
      <h1
        class="text-8xl md:text-9xl font-serif font-bold text-brand-green/20 mb-4 select-none"
      >
        404
      </h1>

      <h2
        class="text-3xl md:text-4xl font-serif font-bold text-brand-green mb-6"
      >
        Oops! Only trees grow here.
      </h2>

      <p class="text-lg text-dark-green mb-10 leading-relaxed">
        The page you are looking for is unfortunately not here. It might have
        been moved, deleted, is waiting to be created, or perhaps you just made
        a typo in the address.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href={getRelativeLocaleUrl(lang, "/")}
          class="w-full sm:w-auto bg-brand-green text-cream px-8 py-3.5 rounded-full font-bold text-lg hover:bg-dark-green transition-colors shadow-lg shadow-brand-green/20"
        >
          Back to the homepage
        </a>
        <a
          href={getRelativeLocaleUrl(lang, "/kontakty")}
          class="w-full sm:w-auto bg-cream/40 backdrop-blur-sm text-dark-green border border-dark-green/20 px-8 py-3.5 rounded-full font-bold text-lg hover:bg-cream/60 transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
