---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Podcast">
  
  <section class="min-h-[70vh] flex items-center pt-12 pb-8 px-4">
    <div class="container mx-auto max-w-4xl">
      
      <!-- Skleněná karta s obsahem -->
      <div class="glass-card rounded-3xl p-8 md:p-16 text-center shadow-xl border border-brand-green/20 relative overflow-hidden">
        
        <!-- Dekorativní prvky na pozadí karty -->
        <div class="absolute -top-10 -right-10 text-brand-green/10 transform rotate-12 pointer-events-none">
          <Icon name="mdi:microphone-variant" class="w-48 h-48" />
        </div>
        <div class="absolute -bottom-10 -left-10 text-brand-green/10 transform -rotate-12 pointer-events-none">
          <Icon name="mdi:headphones" class="w-48 h-48" />
        </div>

        <!-- Hlavní obsah -->
        <div class="relative z-10 flex flex-col items-center">
          
          <span class="inline-block py-1.5 px-4 rounded-full bg-brand-green/10 text-brand-green text-sm font-bold mb-6 tracking-widest uppercase">
            Připravujeme
          </span>
          
          <h1 class="text-5xl md:text-7xl font-serif font-bold text-brand-green mb-6 leading-tight">
            Telperion <span class="italic">Podcast</span>
          </h1>
          
          <p class="text-lg md:text-xl text-dark-green/80 font-medium max-w-2xl mb-10 leading-relaxed">
            Něco velkého se chystá! Brzy pro vás spustíme náš vlastní podcast. Rozhovory, fakta bez strašení a udržitelnost z pohledu mladých. 
            <strong>Ladicí práce finišují, těšte se.</strong>
          </p>

          <!-- Ikonky platforem (zatím neaktivní) -->
          <div class="flex flex-col items-center space-y-4 mb-12">
            <p class="text-sm font-bold text-dark-green uppercase tracking-wide">Najdete nás brzy na:</p>
            <div class="flex gap-6">
              <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-dark-green/40 shadow-sm border border-dark-green/10 cursor-not-allowed" title="Spotify (Již brzy)">
                <Icon name="mdi:spotify" class="w-6 h-6" />
              </div>
              <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-dark-green/40 shadow-sm border border-dark-green/10 cursor-not-allowed" title="Apple Podcasts (Již brzy)">
                <Icon name="mdi:apple" class="w-6 h-6" />
              </div>
              <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-dark-green/40 shadow-sm border border-dark-green/10 cursor-not-allowed" title="YouTube (Již brzy)">
                <Icon name="mdi:youtube" class="w-6 h-6" />
              </div>
            </div>
          </div>

          <!-- Výzva k akci (Otevře kontaktní modal) -->
          <button 
            type="button" 
            onclick="document.dispatchEvent(new CustomEvent('open-contact-modal'))"
            class="bg-brand-green text-cream px-8 py-4 rounded-full font-bold text-lg hover:bg-dark-green transition-transform transform hover:-translate-y-0.5 shadow-lg shadow-brand-green/20 flex items-center gap-2"
          >
            <Icon name="mdi:bell-outline" class="w-5 h-5" />
            Napište nám své nápady
          </button>
          
        </div>
      </div>

    </div>
  </section>

</Layout>