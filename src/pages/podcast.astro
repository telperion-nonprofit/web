---
import { useTranslations, replacePlaceholders } from "../utils/i18n";
import type { Locale } from "../utils/i18n";
const lang = (Astro.currentLocale as Locale) || "cs";
const t = useTranslations(lang);
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import SectionBadge from "../components/SectionBadge.astro";
---

<Layout title={t("podcast.page_title")}>
  <section class="min-h-[70vh] flex items-center pt-12 pb-8 px-4">
    <div class="container mx-auto max-w-4xl">
      <div
        class="glass-card rounded-3xl p-8 md:p-16 text-center shadow-xl border border-brand-green/20 relative overflow-hidden"
      >
        <div
          class="absolute -top-10 -right-10 text-brand-green/10 transform rotate-12 pointer-events-none"
        >
          <Icon name="mdi:microphone-variant" class="w-48 h-48" />
        </div>
        <div
          class="absolute -bottom-10 -left-10 text-brand-green/10 transform -rotate-12 pointer-events-none"
        >
          <Icon name="mdi:headphones" class="w-48 h-48" />
        </div>

        <div class="relative z-10 flex flex-col items-center">
          <SectionBadge class="uppercase tracking-widest">
            {t("podcast.badge")}
          </SectionBadge>

          <h1
            class="text-4xl md:text-5xl font-serif font-bold text-brand-green mb-6 leading-tight"
          >
            {t("podcast.title_main")}
            <span class="italic">{t("podcast.title_highlight")}</span>
          </h1>

          <p
            class="text-lg md:text-xl text-dark-green/80 font-medium max-w-2xl mb-10 leading-relaxed"
          >
            {t("podcast.description")}
            <strong>{t("podcast.description_highlight")}</strong>
          </p>

          <div class="flex flex-col items-center space-y-4 mb-12">
            <p
              class="text-sm font-bold text-dark-green uppercase tracking-wide"
            >
              {t("podcast.platforms_label")}
            </p>
            <div class="flex gap-6">
              <div
                class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-dark-green/40 shadow-sm border border-dark-green/10 cursor-not-allowed"
                title={t("podcast.platform.spotify")}
              >
                <Icon name="mdi:spotify" class="w-6 h-6" />
              </div>
              <div
                class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-dark-green/40 shadow-sm border border-dark-green/10 cursor-not-allowed"
                title={t("podcast.platform.apple")}
              >
                <Icon name="mdi:apple" class="w-6 h-6" />
              </div>
              <div
                class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-dark-green/40 shadow-sm border border-dark-green/10 cursor-not-allowed"
                title={t("podcast.platform.youtube")}
              >
                <Icon name="mdi:youtube" class="w-6 h-6" />
              </div>
            </div>
          </div>

          <button
            type="button"
            onclick="document.dispatchEvent(new CustomEvent('open-contact-modal'))"
            class="bg-brand-green text-cream px-8 py-4 rounded-full font-bold text-lg hover:bg-dark-green transition-transform transform hover:-translate-y-0.5 shadow-lg shadow-brand-green/20 flex items-center gap-2"
          >
            <Icon name="mdi:bell-outline" class="w-5 h-5" />
            {t("podcast.button")}
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>
