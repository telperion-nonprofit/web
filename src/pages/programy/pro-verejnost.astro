---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import SectionBadge from "../../components/SectionBadge.astro";
---

<Layout title="[[public.page_title]]">
  <section class="pt-12 pb-8 text-center px-4 max-w-3xl mx-auto">
    <SectionBadge> [[public.badge]] </SectionBadge>
    <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-green mb-6">
      [[public.title_main]] <span class="italic">[[public.title_highlight]]</span>
    </h1>
    <p class="text-lg text-dark-green/80 font-medium">
      [[public.subtitle]]
    </p>
  </section>

  <div class="container mx-auto max-w-5xl px-4 pb-8 space-y-8">
    <div
      class="glass-card rounded-3xl p-8 md:p-10 flex flex-col md:flex-row gap-8 items-start"
    >
      <div class="md:w-1/3 shrink-0">
        <div class="bg-brand-green text-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-2xl font-serif font-bold mb-4 !text-white">
            [[public.scouts.title]]
          </h3>
          <ul class="space-y-3 text-sm font-medium text-white">
            <li class="flex items-center gap-2">
              <Icon name="mdi:calendar-weekend" class="w-5 h-5" /> [[public.scouts.tag_duration]]
            </li>
            <li class="flex items-center gap-2">
              <Icon name="mdi:account-group" class="w-5 h-5" /> [[public.scouts.tag_participants]]
            </li>
            <li class="flex items-start gap-2">
              <Icon name="mdi:pine-tree" class="w-5 h-5 shrink-0" /> [[public.scouts.tag_groups]]
            </li>
          </ul>
        </div>
      </div>

      <div
        class="md:w-2/3 space-y-4 text-dark-green/80 text-sm leading-relaxed text-justify"
      >
        <p>
          [[public.scouts.desc_p1]]
        </p>
        <p>
          <strong>[[public.scouts.desc_p2_youngest]]</strong> [[public.scouts.desc_p2_youngest_text]]
          <strong>[[public.scouts.desc_p2_scouts]]</strong> [[public.scouts.desc_p2_scouts_text]]
        </p>
        <p>
          [[public.scouts.desc_p3_before]]
          <strong>[[public.scouts.desc_p3_bold]]</strong> [[public.scouts.desc_p3_after]]
        </p>
      </div>
    </div>

    <div
      class="bg-white/60 backdrop-blur-sm border border-white rounded-3xl p-8 md:p-10 flex flex-col md:flex-row gap-8 items-start"
    >
      <div class="md:w-1/3 shrink-0">
        <h3 class="text-2xl font-serif font-bold text-brand-green mb-4">
          [[public.fresk.title]]
        </h3>
        <ul class="space-y-3 text-sm text-dark-green font-medium">
          <li class="flex items-center gap-2">
            <Icon name="mdi:clock-outline" class="w-5 h-5 text-brand-green" /> [[public.fresk.tag_duration]]
          </li>
          <li class="flex items-center gap-2">
            <Icon name="mdi:account-check" class="w-5 h-5 text-brand-green" /> [[public.fresk.tag_age]]
          </li>
          <li class="flex items-center gap-2">
            <Icon
              name="mdi:account-multiple"
              class="w-5 h-5 text-brand-green"
            /> [[public.fresk.tag_capacity]]
          </li>
        </ul>
      </div>

      <div class="md:w-2/3 text-dark-green/80 text-sm leading-relaxed">
        <p>
          [[public.fresk.desc_p1]]
        </p>
        <p class="mt-4">
          [[public.fresk.desc_p2_before]] <em>[[public.fresk.desc_p2_note]]</em>.
        </p>
      </div>
    </div>
  </div>
</Layout>
