---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import SectionBadge from "../../components/SectionBadge.astro";

const realizace = [
  "[[schools.realizations.1]]",
  "[[schools.realizations.2]]",
  "[[schools.realizations.3]]",
  "[[schools.realizations.4]]",
  "[[schools.realizations.5]]",
  "[[schools.realizations.6]]",
  "[[schools.realizations.7]]",
  "[[schools.realizations.8]]",
  "[[schools.realizations.9]]",
  "[[schools.realizations.10]]",
];
---

<Layout title="[[schools.page_title]]">
  <section class="pt-12 pb-8 text-center px-4 max-w-3xl mx-auto">
    <SectionBadge> [[schools.badge]] </SectionBadge>
    <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-green mb-6">
      [[schools.title_main]] <span class="italic">[[schools.title_highlight]]</span>
    </h1>
    <p class="text-lg text-dark-green/80 font-medium">
      [[schools.subtitle]]
    </p>
  </section>

  <section class="px-4 pb-8 container mx-auto max-w-6xl">
    <div class="glass-card rounded-[2.5rem] p-8 md:p-12">
      <div
        class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6 border-b border-brand-green/10 pb-8"
      >
        <div>
          <h2 class="text-3xl font-serif font-bold text-brand-green mb-2">
            [[schools.climate_days.title]]
          </h2>
          <p class="text-dark-green font-medium">
            [[schools.climate_days.subtitle]]
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <span
            class="flex items-center gap-2 bg-white/50 px-4 py-2 rounded-xl text-sm font-bold text-dark-green shadow-sm"
          >
            <Icon name="mdi:clock-outline" class="w-5 h-5 text-brand-green" /> [[schools.climate_days.tag_duration]]
          </span>
          <span
            class="flex items-center gap-2 bg-white/50 px-4 py-2 rounded-xl text-sm font-bold text-dark-green shadow-sm"
          >
            <Icon name="mdi:account-group" class="w-5 h-5 text-brand-green" /> [[schools.climate_days.tag_participants]]
          </span>
          <span
            class="flex items-center gap-2 bg-white/50 px-4 py-2 rounded-xl text-sm font-bold text-dark-green shadow-sm"
          >
            <Icon name="mdi:school-outline" class="w-5 h-5 text-brand-green" /> [[schools.climate_days.tag_level]]
          </span>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 mb-12">
        <div class="space-y-4 text-dark-green/80 leading-relaxed text-justify">
          <p>
            [[schools.climate_days.desc_p1]]
          </p>
          <p>
            [[schools.climate_days.desc_p2_before]] <strong>[[schools.climate_days.desc_p2_bold]]</strong>[[schools.climate_days.desc_p2_after]]
          </p>
          <p>
            [[schools.climate_days.desc_p3]]
          </p>
        </div>

        <div
          class="bg-white/40 rounded-2xl p-6 md:p-8 space-y-6 shadow-sm border border-white/50"
        >
          <div>
            <h4
              class="font-bold text-brand-green text-lg mb-2 flex items-center gap-2"
            >
              <span
                class="bg-brand-green text-white w-6 h-6 flex items-center justify-center rounded-full text-sm"
                >1</span
              >
              [[schools.climate_days.day1_title]]
            </h4>
            <p class="text-sm text-dark-green/80">
              [[schools.climate_days.day1_desc]]
            </p>
          </div>
          <div>
            <h4
              class="font-bold text-brand-green text-lg mb-2 flex items-center gap-2"
            >
              <span
                class="bg-brand-green text-white w-6 h-6 flex items-center justify-center rounded-full text-sm"
                >2</span
              >
              [[schools.climate_days.day2_title]]
            </h4>
            <p class="text-sm text-dark-green/80">
              [[schools.climate_days.day2_desc]]
            </p>
          </div>
        </div>
      </div>

      <div class="mt-8">
        <h4
          class="text-sm uppercase tracking-wider font-bold text-dark-green/50 mb-4"
        >
          [[schools.realizations_title]]
        </h4>
        <div class="flex flex-wrap gap-2">
          {
            realizace.map((skola) => (
              <span class="text-xs font-medium px-3 py-1.5 bg-brand-green/5 text-dark-green rounded-lg border border-brand-green/10">
                {skola}
              </span>
            ))
          }
          <span
            class="text-xs font-bold px-3 py-1.5 text-brand-green italic flex items-center"
          >
            [[schools.realizations_more]]
          </span>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 pb-8 container mx-auto max-w-2xl">
    <h3 class="text-2xl font-serif font-bold text-brand-green mb-6 text-center">
      [[schools.other_formats.title]]
    </h3>

    <div class="grid gap-8">
      <div
        class="bg-white/60 backdrop-blur-sm rounded-3xl p-8 border border-white transform-gpu will-change-transform transition-transform hover:-translate-y-1 hover:shadow-lg"
      >
        <h3 class="text-xl font-bold text-brand-green mb-3">
          [[schools.other_formats.fresk.title]]
        </h3>
        <div class="flex gap-4 mb-4">
          <span
            class="text-xs font-bold bg-cream px-2 py-1 rounded-md text-dark-green"
            ><Icon name="mdi:clock-outline" class="inline w-4 h-4 mr-1" /> [[schools.other_formats.fresk.duration]]</span
          >
          <span
            class="text-xs font-bold bg-cream px-2 py-1 rounded-md text-dark-green"
            >[[schools.other_formats.fresk.ideal]]</span
          >
        </div>
        <p class="text-dark-green/80 text-sm">
          [[schools.other_formats.fresk.description]]
        </p>
      </div>
    </div>
  </section>
</Layout>
