---
import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/FeatureCard.astro';
---

<Layout title="Domů">
  
  <!-- HERO SEKCE -->
  <section class="relative pt-12 pb-8 md:pt-16 md:pb-8 overflow-hidden">
    <!-- Větší boční padding pro hezčí vzhled na noteboocích -->
    <div class="container mx-auto px-6 md:px-12 lg:px-16 text-center max-w-5xl">
      <span class="inline-block py-1 px-3 rounded-full bg-cream/80 backdrop-blur-sm text-dark-green text-sm font-bold mb-6 tracking-wide border border-brand-green/30">
        🚧 Naše nové stránky právě klíčí
      </span>
      <h1 class="text-5xl md:text-7xl font-serif font-bold text-brand-green mb-6 leading-tight">
        Mladí učí <span class="italic">o klimatu</span>
      </h1>
      <p class="text-lg md:text-xl text-dark-green mb-10 leading-relaxed max-w-2xl mx-auto font-medium">
        Informujeme o tématech spojených s životním prostředím. Vzděláváme a přibližujeme udržitelný způsob života mladé generaci.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <!-- Odkazy nyní vedou na tvé nové podstránky -->
        <a href="/programy/pro-skoly" class="w-full sm:w-auto bg-brand-green text-cream px-8 py-4 rounded-full font-bold text-lg hover:bg-dark-green transition transform hover:-translate-y-0.5 shadow-xl shadow-brand-green/20">
          Programy pro školy
        </a>
        <a href="/kontakty" class="w-full sm:w-auto bg-cream/50 backdrop-blur-sm text-dark-green border border-brand-green/30 px-8 py-4 rounded-full font-bold text-lg hover:bg-white/60 transition">
          Náš tým
        </a>
      </div>
    </div>
  </section>

  <!-- JEMNÁ DĚLÍCÍ ČÁRA MEZI HERO A MAPOU -->
  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    <hr class="max-w-5xl mx-auto border-t border-dark-green/10" />
  </div>

  <!-- SEKCE: MAPA PŮSOBNOSTI -->
  <section class="pt-12 pb-8 md:pt-16 md:pb-8">
    <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-6xl">
      
      <div class="text-center mb-10 max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-brand-green mb-4">
          Kde všude už jsme <span class="italic">byli?</span>
        </h2>
        <p class="text-dark-green text-lg font-medium">
          S našimi programy jezdíme za žáky a studenty po celé České republice. Podívejte se, kde všude už Telperion zapustil kořeny.
        </p>
      </div>

      <!-- 
        Obal pro mapu: 
        Přidáno 'relative' a 'overflow-hidden' pro oříznutí přečnívající části iframe 
      -->
      <div class="relative w-full aspect-square sm:aspect-video md:aspect-[21/9] rounded-3xl md:rounded-[2.5rem] overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-brand-green/20 bg-brand-green/5">
        
        <!-- 
          Změna CSS pro Iframe:
          Uděláme iframe o něco vyšší (calc(100% + 40px)) a posuneme ho nahoru (-top-0). 
          Díky overflow-hidden na obalu se ten spodní okraj s textem schová.
        -->
        <iframe 
          class="absolute left-0 top-0 w-full border-0"
          style="height: calc(100% + 40px);"
          allowfullscreen 
          allow="geolocation" 
          src="https://umap.openstreetmap.fr/cs-cz/map/mapa-telperionu_1371476?scaleControl=false&miniMap=false&scrollWheelZoom=true&zoomControl=true&editMode=disabled&moreControl=true&searchControl=null&tilelayersControl=null&embedControl=null&datalayersControl=true&onLoadPanel=none&captionBar=false&captionMenus=true#7/49.800/15.500">
        </iframe>
        
        <!-- Jemný zelený překryv pro sladění s barevností webu -->
        <div class="absolute inset-0 bg-brand-green/5 pointer-events-none mix-blend-overlay"></div>
      </div>

    </div>
  </section>

  <!-- JEMNÁ DĚLÍCÍ ČÁRA -->
  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    <hr class="max-w-5xl mx-auto border-t border-dark-green/10" />
  </div>

  <!-- SEKCE: PROČ TO FUNGUJE? -->
  <section class="pt-16 pb-4 md:pt-20 md:pb-6">
    <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl">
      
      <div class="text-center mb-16 max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-brand-green mb-4">
          Proč to funguje?
        </h2>
        <p class="text-dark-green text-lg font-medium">
          Věříme, že o klimatu se dá mluvit bez strašení a složitých grafů. Náš přístup stavíme na dialogu a faktech.
        </p>
      </div>

      <!-- Zvětšili jsme i mezeru (gap-10) mezi jednotlivými kartami pro vzdušnější dojem -->
      <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
        
        <FeatureCard
          icon="mdi:account-group-outline"
          title="Rovnocenný přístup"
        >
          Jsme studenti, stejně jako naše publikum. Nepoučujeme z pozice autority, ale diskutujeme jako vrstevníci. Odbouráváme bariéry a trému.
        </FeatureCard>

        <FeatureCard
          icon="mdi:earth"
          title="Ověřená fakta"
        >
          Naše materiály nestavíme na dojmech. Čerpáme z ověřených vědeckých studií a dat (IPCC, Fakta o klimatu) a překládáme je do lidské řeči.
        </FeatureCard>

        <FeatureCard
          icon="mdi:lightbulb-on-outline"
          title="Interaktivita"
        >
          Žádné monology. Používáme hry, workshopy a diskuze. Chceme, aby si žáci na věci přišli sami a vytvořili si vlastní názor.
        </FeatureCard>

      </div>
    </div>
  </section>

</Layout>