---
import { useTranslations, replacePlaceholders } from "../utils/i18n";
import type { Locale } from "../utils/i18n";
const lang = (Astro.currentLocale as Locale) || "cs";
const t = useTranslations(lang);
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "../layouts/Layout.astro";
import FeatureCard from "../components/FeatureCard.astro";
import SectionBadge from "../components/SectionBadge.astro";
---

<Layout title={t("home.page_title")}>
  <section class="relative pt-12 pb-8 md:pt-16 md:pb-8 overflow-hidden">
    <div class="container mx-auto px-6 md:px-12 lg:px-16 text-center max-w-5xl">
      <SectionBadge> {t("home.hero.badge")} </SectionBadge>
      <h1
        class="text-5xl md:text-7xl font-serif font-bold text-brand-green mb-6 leading-tight"
      >
        {t("home.hero.title_main")} <span class="italic"
          >{t("home.hero.title_highlight")}</span
        >
      </h1>
      <p
        class="text-lg md:text-xl text-dark-green mb-10 leading-relaxed max-w-2xl mx-auto font-medium"
      >
        {t("home.hero.description")}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href={getRelativeLocaleUrl(lang, "/programy/pro-skoly")}
          class="w-full sm:w-auto bg-brand-green text-cream px-8 py-4 rounded-full font-bold text-lg hover:bg-dark-green transition transform hover:-translate-y-0.5 shadow-xl shadow-brand-green/20"
        >
          {t("home.hero.button_programs")}
        </a>
        <a
          href={getRelativeLocaleUrl(lang, "/kontakty")}
          class="w-full sm:w-auto bg-cream/50 backdrop-blur-sm text-dark-green border border-brand-green/30 px-8 py-4 rounded-full font-bold text-lg hover:bg-white/60 transition"
        >
          {t("home.hero.button_team")}
        </a>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    <hr class="max-w-5xl mx-auto border-t border-dark-green/10" />
  </div>

  <section class="pt-12 pb-8 md:pt-16 md:pb-8">
    <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-6xl">
      <div class="text-center mb-10 max-w-3xl mx-auto">
        <h2
          class="text-3xl md:text-4xl font-serif font-bold text-brand-green mb-4"
        >
          {t("home.map.title_main")} <span class="italic"
            >{t("home.map.title_highlight")}</span
          >
        </h2>
        <p class="text-dark-green text-lg font-medium">
          {t("home.map.description")}
        </p>
      </div>

      <div
        class="relative w-full aspect-square sm:aspect-video md:aspect-[21/9] rounded-3xl md:rounded-[2.5rem] overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-brand-green/20 bg-brand-green/5"
      >
        <iframe
          id="umap-iframe"
          class="absolute left-0 top-0 w-full border-0"
          style="height: calc(100% + 40px);"
          allowfullscreen
          allow="geolocation"
          src="https://umap.openstreetmap.fr/cs-cz/map/mapa-telperionu_1371476?scaleControl=false&miniMap=false&scrollWheelZoom=true&zoomControl=true&editMode=disabled&moreControl=true&searchControl=null&tilelayersControl=null&embedControl=null&datalayersControl=true&onLoadPanel=none&captionBar=false&captionMenus=true#7/49.800/15.500"
        >
        </iframe>

        <div
          class="absolute inset-0 bg-brand-green/5 pointer-events-none mix-blend-overlay"
        >
        </div>
      </div>

      <div
        class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-2 text-center text-sm font-medium text-dark-green/80"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-brand-green flex-shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
        <span> {t("home.map.layers_tip")} </span>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    <hr class="max-w-5xl mx-auto border-t border-dark-green/10" />
  </div>

  <section class="pt-16 pb-12 md:pt-20 md:pb-16">
    <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl">
      <div class="text-center mb-16 max-w-3xl mx-auto">
        <h2
          class="text-3xl md:text-4xl font-serif font-bold text-brand-green mb-4"
        >
          {t("home.features.title")}
        </h2>
        <p class="text-dark-green text-lg font-medium">
          {t("home.features.description")}
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
        <FeatureCard
          icon="mdi:account-group-outline"
          title={t("home.features.card1.title")}
        >
          {t("home.features.card1.text")}
        </FeatureCard>

        <FeatureCard icon="mdi:earth" title={t("home.features.card2.title")}>
          {t("home.features.card2.text")}
        </FeatureCard>

        <FeatureCard
          icon="mdi:lightbulb-on-outline"
          title={t("home.features.card3.title")}
        >
          {t("home.features.card3.text")}
        </FeatureCard>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    <hr class="max-w-5xl mx-auto border-t border-dark-green/10" />
  </div>

  <!-- SEKCE: RECENZE -->
  <section class="pt-16 pb-20 md:pt-20 md:pb-24">
    <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl">
      <div class="text-center mb-16 max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-brand-green mb-4">
          Co o nás <span class="italic">říkají ostatní?</span>
        </h2>
        <p class="text-dark-green text-lg font-medium">
          Zpětná vazba od účastníků a partnerů našich programů je pro nás důležitá.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <!-- Recenze 1 -->
        <div class="glass-card rounded-3xl p-8 flex flex-col shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-brand-green/20 relative">
          <svg class="absolute top-6 right-8 w-10 h-10 text-brand-green/10" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-dark-green/90 leading-relaxed italic mb-8 flex-grow relative z-10">
            "Díky Jakubovi a celému Telperionu za super Klima dny na Biskupském gymnáziu v ČB! Organizace a příprava byla na profesionálním levelu. Studenti si odnesli mnoho nových poznatků a akce je dovedla k hlubšímu zamyšlení nad klimatickou krizí. Doufám, že je Klima dny inspirovaly i k další ekologické činnosti."
          </p>
          <div class="mt-auto pt-6 border-t border-brand-green/10">
            <h4 class="font-bold text-brand-green text-lg">Karolína Bittová</h4>
            <span class="text-sm text-dark-green/60 font-medium">21. 06. 2023</span>
          </div>
        </div>

        <!-- Recenze 2 -->
        <div class="glass-card rounded-3xl p-8 flex flex-col shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-brand-green/20 relative">
          <svg class="absolute top-6 right-8 w-10 h-10 text-brand-green/10" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-dark-green/90 leading-relaxed italic mb-8 flex-grow relative z-10">
            "Jakubovu iniciativu znám jako přednášející na Klimatických dnech v minulém roce - přijde mi důležité, aby téma ochrany klimatu a životního prostředí vnášeli do školního prostředí právě studující a navíc mají tah na dlouhodobější akce, což Klimatické dny, zdá se, nyní budou a úspěšně se šířit. Ocenění práce na školách, kde se klíčová témata pro naši budoucnost prosazují jen pomalu, si podle mne zaslouží ocenění."
          </p>
          <div class="mt-auto pt-6 border-t border-brand-green/10">
            <h4 class="font-bold text-brand-green text-lg">Anna Kárníková</h4>
            <span class="text-sm text-dark-green/60 font-medium">04. 05. 2023</span>
          </div>
        </div>

        <!-- Recenze 3 -->
        <div class="glass-card rounded-3xl p-8 flex flex-col shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-brand-green/20 relative">
          <svg class="absolute top-6 right-8 w-10 h-10 text-brand-green/10" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-dark-green/90 leading-relaxed italic mb-8 flex-grow relative z-10">
            "Jakuba znám přímo z akce Klimatické dny, kde jsem v roce 2022 vedla jeden z programů. Od té doby často zmiňuji jeho iniciativu jako skvělý počin, který každoročně podněcuje studenty napříč věkovými kategoriemi k hlubšímu přemýšlení o souvislostech komplikovaného vztahu mezi člověkem a jeho životním prostředím."
          </p>
          <div class="mt-auto pt-6 border-t border-brand-green/10">
            <h4 class="font-bold text-brand-green text-lg">Magdalena Davis</h4>
            <span class="text-sm text-dark-green/60 font-medium">20. 04. 2023</span>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  import { getSafeLanguage } from "../utils/lang";

  const iframe = document.getElementById("umap-iframe") as HTMLIFrameElement;
  if (iframe) {
    const lang = getSafeLanguage();
    const umapLang = lang === "en" ? "en" : "cs-cz";
    iframe.src = iframe.src.replace(
      /openstreetmap\.fr\/[a-z-]+\/map/,
      `openstreetmap.fr/${umapLang}/map`,
    );
  }
</script>