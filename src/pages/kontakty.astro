---

<Layout title="Náš tým a Kontakty">
  <section
    class="relative pt-12 pb-8 md:pt-16 md:pb-8 overflow-hidden text-center"
  >
    <div class="container mx-auto px-4 max-w-4xl">
      <SectionBadge> Náš tým </SectionBadge>
      <h1
        class="text-4xl md:text-6xl font-serif font-bold text-brand-green mb-6"
      >
        Kdo za spolkem <span class="italic">stojí?</span>
      </h1>
      <p
        class="text-lg md:text-xl text-dark-green mb-8 leading-relaxed max-w-2xl mx-auto font-medium"
      >
        Jsme skupina studentů, kteří chtějí změnit způsob, jakým se u nás mluví
        o klimatu. Seznamte se s námi!
      </p>

      <div class="mb-4">
        <a
          href="mailto:info@telperion.cz"
          class="inline-flex items-center gap-3 text-brand-green font-bold text-xl hover:text-dark-green transition-all bg-white/50 backdrop-blur-sm px-8 py-3 rounded-full border border-brand-green/20 hover:bg-white/80 hover:shadow-lg hover:-translate-y-0.5"
        >
          <Icon name="mdi:email-outline" class="w-6 h-6" />
          info@telperion.cz
        </a>
      </div>

      <button
        type="button"
        class="lightbox-trigger mt-10 rounded-3xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-brand-green/20 cursor-zoom-in"
        data-full-src={teamPhoto.src}
      >
        <Image
          src={teamPhoto}
          alt="Tým Telperion"
          class="w-full h-auto"
          widths={[480, 768, 1024]}
          sizes="(max-width: 768px) 100vw, 768px"
          quality={60}
        />
      </button>
    </div>
  </section>

  <section class="pb-8 md:pb-8">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          teamMembers.map((member) => (
            <div class="glass-card rounded-3xl p-6 sm:p-8 transform-gpu will-change-transform h-full flex flex-col transition-transform duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-green/10">
              <div class="w-24 h-24 rounded-full bg-brand-green/10 flex items-center justify-center text-brand-green mb-6 mx-auto overflow-hidden border-2 border-brand-green/20">
                {member.image ? (
                  <Image
                    src={member.image}
                    alt={member.name}
                    class="w-full h-full object-cover"
                    width={96}
                    height={96}
                    quality={60}
                  />
                ) : (
                  <span class="text-3xl font-serif font-bold">
                    {member.name.charAt(0)}
                  </span>
                )}
              </div>

              <div class="text-center mb-4">
                <h3 class="text-2xl font-serif font-bold text-brand-green mb-1">
                  {member.name}
                </h3>
                <p class="text-sm font-bold text-dark-green/60 uppercase tracking-wider">
                  {member.role}
                </p>
              </div>

              <div class="flex flex-col gap-2 mt-auto">
                {member.email && (
                  <a
                    href={`mailto:${member.email}`}
                    class="flex items-center gap-3 text-sm text-dark-green font-medium hover:text-brand-green transition-colors p-2 rounded-xl hover:bg-white/40"
                  >
                    <Icon
                      name="mdi:email-outline"
                      class="w-5 h-5 text-brand-green flex-shrink-0"
                    />
                    <span class="truncate">{member.email}</span>
                  </a>
                )}
                {member.phone && (
                  <a
                    href={`tel:${member.phone.replace(/\s+/g, "")}`}
                    class="flex items-center gap-3 text-sm text-dark-green font-medium hover:text-brand-green transition-colors p-2 rounded-xl hover:bg-white/40"
                  >
                    <Icon
                      name="mdi:phone-outline"
                      class="w-5 h-5 text-brand-green flex-shrink-0"
                    />
                    <span>{member.phone}</span>
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-16 md:mt-24 max-w-4xl mx-auto">
        <div
          class="glass-card rounded-3xl p-8 sm:p-12 text-center md:text-left border border-brand-green/20"
        >
          <h2
            class="text-3xl font-serif font-bold text-brand-green mb-8 text-center"
          >
            Údaje o spolku
          </h2>

          <div class="grid md:grid-cols-3 gap-8">
            <div class="flex flex-col items-center md:items-start">
              <div
                class="w-12 h-12 rounded-xl bg-brand-green/10 flex items-center justify-center text-brand-green mb-4 border border-brand-green/20"
              >
                <Icon name="mdi:office-building-marker" class="w-6 h-6" />
              </div>
              <h3 class="text-lg font-bold text-brand-green mb-2">
                Sídlo spolku
              </h3>
              <p class="text-dark-green/80 text-sm font-medium">
                Úvozová 261/6, 252 62
              </p>
            </div>

            <div class="flex flex-col items-center md:items-start">
              <div
                class="w-12 h-12 rounded-xl bg-brand-green/10 flex items-center justify-center text-brand-green mb-4 border border-brand-green/20"
              >
                <Icon name="mdi:identifier" class="w-6 h-6" />
              </div>
              <h3 class="text-lg font-bold text-brand-green mb-2">IČO</h3>
              <p class="text-dark-green/80 text-sm font-medium">21104271</p>
            </div>

            <div class="flex flex-col items-center md:items-start">
              <div
                class="w-12 h-12 rounded-xl bg-brand-green/10 flex items-center justify-center text-brand-green mb-4 border border-brand-green/20"
              >
                <Icon name="mdi:bank-outline" class="w-6 h-6" />
              </div>
              <h3 class="text-lg font-bold text-brand-green mb-2">
                Transparentní účet
              </h3>
              <p class="text-dark-green/80 text-sm font-medium break-all">
                2102801318 / 2010
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<div
  id="photo-lightbox"
  class="fixed inset-0 z-[200] hidden items-center justify-center p-6 sm:p-10 md:p-16"
  role="dialog"
  aria-modal="true"
  aria-label="Photo lightbox"
>
  <div
    id="lightbox-backdrop"
    class="absolute inset-0 bg-dark-green/70 backdrop-blur-sm transition-opacity duration-300 opacity-0"
  >
  </div>
  <img
    id="lightbox-img"
    src=""
    alt=""
    class="relative z-10 max-w-full max-h-full rounded-3xl shadow-2xl object-contain transition-all duration-300 scale-95 opacity-0"
  />
  <button
    type="button"
    id="lightbox-close"
    class="absolute top-4 right-4 z-20 text-cream/80 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
    aria-label="Close"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>

<script>
  const lightbox = document.getElementById("photo-lightbox") as HTMLDivElement;
  const lightboxImg = document.getElementById(
    "lightbox-img",
  ) as HTMLImageElement;
  const lightboxBackdrop = document.getElementById(
    "lightbox-backdrop",
  ) as HTMLDivElement;
  const lightboxClose = document.getElementById(
    "lightbox-close",
  ) as HTMLButtonElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    requestAnimationFrame(() => {
      lightboxBackdrop.classList.remove("opacity-0");
      lightboxBackdrop.classList.add("opacity-100");
      lightboxImg.classList.remove("scale-95", "opacity-0");
      lightboxImg.classList.add("scale-100", "opacity-100");
    });
  }

  function closeLightbox() {
    lightboxBackdrop.classList.remove("opacity-100");
    lightboxBackdrop.classList.add("opacity-0");
    lightboxImg.classList.remove("scale-100", "opacity-100");
    lightboxImg.classList.add("scale-95", "opacity-0");
    setTimeout(() => {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightboxImg.src = "";
    }, 300);
  }

  document.querySelectorAll(".lightbox-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = (btn as HTMLElement).dataset.fullSrc || "";
      const alt = btn.querySelector("img")?.alt || "";
      openLightbox(src, alt);
    });
  });

  lightboxClose.addEventListener("click", closeLightbox);
  lightboxBackdrop.addEventListener("click", closeLightbox);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !lightbox.classList.contains("hidden")) {
      closeLightbox();
    }
  });
</script>
