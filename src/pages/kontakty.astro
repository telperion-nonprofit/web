    email: "sofia.grycova@telperion.cz",
    phone: "",
    image: null,
  },
  {
    name: "David Bartoš",
    role: "Lektor klima dnů, facilitace climate fresk",
    email: "david.bartos@telperion.cz",
    phone: "",
    image: null,
