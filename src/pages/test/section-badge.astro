---
import SectionBadgeComponent from "../../components/SectionBadge.astro";
import Layout from "../../layouts/Layout.astro";

if (import.meta.env.PROD) {
  return Astro.redirect("/", 302);
}
---

<Layout title="Test SectionBadge" noindex={true}>
  <div class="p-8 space-y-8">
    <SectionBadgeComponent data-testid="badge-default">
      Default Badge
    </SectionBadgeComponent>

    <SectionBadgeComponent class="custom-class" data-testid="badge-custom-class">
      Custom Class Badge
    </SectionBadgeComponent>

    <SectionBadgeComponent id="badge-with-id" data-testid="badge-with-id">
      Badge with ID
    </SectionBadgeComponent>

    <SectionBadgeComponent data-testid="badge-complex-slot">
      <span>Complex</span>
      <strong>Slot</strong>
    </SectionBadgeComponent>
  </div>
</Layout>
