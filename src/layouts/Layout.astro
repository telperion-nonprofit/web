---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "@fontsource-variable/manrope";
import "@fontsource-variable/playfair-display";
import "@fontsource-variable/playfair-display/wght-italic.css";
import "../styles/global.css";
import { Image } from "astro:assets";
import leaves from "../assets/leaves.svg";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Modal from "../components/Modal.astro";
import DonationModal from "../components/DonationModal.astro";

import { replacePlaceholders } from "../utils/i18n";
import type { Locale } from "../utils/i18n";

interface Props {
  title?: string;
  description?: string;
}

const lang = (Astro.currentLocale as Locale) || "cs";

const {
  title,
  description = "Mladí učí o klimatu. Vzdělávací programy pro školy a veřejnost.",
} = Astro.props;

const translatedTitle = title ? replacePlaceholders(title, lang) : undefined;
const translatedDesc = description
  ? replacePlaceholders(description, lang)
  : undefined;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={translatedDesc} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <meta
      property="og:title"
      content={`${translatedTitle || "Domů"} | Telperion`}
    />
    <meta property="og:description" content={translatedDesc} />
    <meta property="og:type" content="website" />
    <title>
      {translatedTitle ? `${translatedTitle} | Telperion` : "Telperion"}
    </title>
    <link rel="preconnect" href="https://umap.openstreetmap.fr" crossorigin />
    <link rel="preconnect" href="https://tile.openstreetmap.org" crossorigin />
    <Analytics />
    <SpeedInsights />
  </head>

  <body class="bg-cream text-dark-green font-sans antialiased">
    <div class="relative overflow-hidden flex flex-col min-h-screen">
      <div
        class="absolute top-0 right-0 w-64 md:w-96 opacity-90 pointer-events-none z-0"
      >
        <Image
          src={leaves}
          alt=""
          fetchpriority="high"
          loading="eager"
          width={429}
          height={317}
        />
      </div>
      <div
        class="absolute bottom-0 left-0 rotate-180 w-64 md:w-96 opacity-90 pointer-events-none z-0"
      >
        <Image
          src={leaves}
          alt=""
          fetchpriority="high"
          loading="eager"
          width={429}
          height={317}
        />
      </div>

      <Navbar />

      <main class="flex-grow flex flex-col relative z-10 pt-24 pb-0">
        <slot />
      </main>

      <div class="relative z-20">
        <Footer />
      </div>
    </div>

    <Modal />
    <DonationModal />
    <script>
      import {
        Tolgee,
        FormatSimple,
        DevTools,
        ObserverPlugin,
      } from "@tolgee/web";
      import { getSafeLanguage } from "../utils/lang";

      const isDev = import.meta.env.DEV;
      const savedLanguage = getSafeLanguage();

      const translationsModule =
        savedLanguage === "en"
          ? await import("../i18n/en.json")
          : await import("../i18n/cs-CZ.json");
      const activeTranslations = translationsModule.default;

      const tolgee = Tolgee()
        .use(FormatSimple())
        .use(isDev ? DevTools() : ObserverPlugin())
        .init({
          language: savedLanguage,
          defaultLanguage: "cs-CZ",
          ...(isDev && {
            apiKey: import.meta.env.PUBLIC_TOLGEE_API_KEY,
            apiUrl: import.meta.env.PUBLIC_TOLGEE_API_URL,
          }),
          observerType: "text",
          observerOptions: { inputPrefix: "[[", inputSuffix: "]]" },
          staticData: {
            [savedLanguage]: activeTranslations,
          },
        });

      tolgee.run().catch((e) => {
        console.error("Tolgee initialization failed:", e);
      });
    </script>
  </body>
</html>
