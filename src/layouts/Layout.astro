---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "@fontsource-variable/manrope";
import "@fontsource-variable/playfair-display";
import "@fontsource-variable/playfair-display/wght-italic.css";
import "../styles/global.css";
import { Image } from "astro:assets";
import leaves from "../assets/leaves.svg";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Modal from "../components/Modal.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title,
  description = "Mladí učí o klimatu. Vzdělávací programy pro školy a veřejnost.",
} = Astro.props;
const pageTitle = title
  ? `${title} | Mladí učí o klimatu`
  : "Mladí učí o klimatu";
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta property="og:title" content={`${title} | Telperion`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title} | Telperion</title>
    <Analytics />
    <SpeedInsights />
  </head>

  <body class="bg-cream text-dark-green font-sans antialiased">
    <div class="relative overflow-hidden flex flex-col min-h-screen">
      <div
        class="absolute top-0 right-0 w-64 md:w-96 opacity-90 pointer-events-none z-0"
      >
        <Image src={leaves} alt="" fetchpriority="high" loading="eager" />
      </div>
      <div
        class="absolute bottom-0 left-0 rotate-180 w-64 md:w-96 opacity-90 pointer-events-none z-0"
      >
        <Image src={leaves} alt="" fetchpriority="high" loading="eager" />
      </div>

      <Navbar />

      <main class="flex-grow flex flex-col relative z-10 pt-24 pb-0">
        <slot />
      </main>

      <div class="relative z-20">
        <Footer />
      </div>
    </div>

    <Modal />
    <script>
      import { Tolgee, FormatSimple, DevTools, ObserverPlugin } from "@tolgee/web";
      import enTranslations from "../i18n/en.json";
      import csTranslations from "../i18n/cs-CZ.json";

      const isDev = import.meta.env.DEV;

      // 1. Zjistíme, jestli si uživatel jazyk už ručně nepřepnul v minulosti
      let savedLanguage = localStorage.getItem("zvoleny-jazyk");

      // 2. Pokud u nás uživatel ještě nikdy nebyl, detekujeme jazyk z jeho prohlížeče
      if (!savedLanguage) {
        const browserLang = navigator.language.slice(0, 2);
        savedLanguage =
          browserLang === "en" ? "en" : "cs-CZ";
      }

      const tolgee = Tolgee()
        .use(FormatSimple())
        .use(isDev ? DevTools() : ObserverPlugin())
        .init({
          language: savedLanguage,
          defaultLanguage: 'cs-CZ',
          ...(isDev && {
            apiKey: import.meta.env.PUBLIC_TOLGEE_API_KEY,
            apiUrl: import.meta.env.PUBLIC_TOLGEE_API_URL,
          }),
          observerType: 'text',
          observerOptions: { inputPrefix: '[[', inputSuffix: ']]' },
          staticData: {
            en: enTranslations,
            "cs-CZ": csTranslations,
          }
        });

      tolgee.run().catch((e) => {
        console.error("Tolgee initialization failed:", e);
      });
    </script>
  </body>
</html>
