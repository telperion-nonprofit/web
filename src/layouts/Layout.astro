---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "@fontsource-variable/manrope";
import "@fontsource-variable/playfair-display";
import "@fontsource-variable/playfair-display/wght-italic.css";
import "../styles/global.css";
import { Image } from "astro:assets";
import leaves from "../assets/leaves.svg";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Modal from "../components/Modal.astro";
import DonationModal from "../components/DonationModal.astro";

import { replacePlaceholders } from "../utils/i18n";
import type { Locale } from "../utils/i18n";
import { routeMap, getSafeLanguage } from "../utils/lang";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const lang = (Astro.currentLocale as Locale) || "cs";
const htmlLang = lang === "en" ? "en" : "cs-CZ";

const {
  title,
  description = "Mladí učí o klimatu. Vzdělávací programy pro školy a veřejnost.",
  image,
  noindex = false,
} = Astro.props;

const translatedTitle = title ? replacePlaceholders(title, lang) : undefined;
const translatedDesc = description
  ? replacePlaceholders(description, lang)
  : undefined;

// Create canonical URL without query parameters
const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://www.telperion.cz",
);

// Helper to create hreflang URLs
const getHreflangUrl = (targetLang: string) => {
  let currentPath = Astro.url.pathname;
  if (
    currentPath !== "/" &&
    currentPath !== "/en/" &&
    currentPath.endsWith("/")
  ) {
    currentPath = currentPath.slice(0, -1);
  }

  const isEnglishPath = currentPath === "/en" || currentPath.startsWith("/en/");

  let newPath = currentPath;

  if (targetLang === "en") {
    // If not already an English path, translate or add /en prefix
    if (!isEnglishPath) {
      // Find english path
      let found = false;
      for (const [czBase, enBase] of Object.entries(routeMap)) {
        if (currentPath === czBase) {
          newPath = enBase;
          found = true;
          break;
        } else if (currentPath.startsWith(`${czBase}/`)) {
          newPath = currentPath.replace(czBase, enBase);
          found = true;
          break;
        }
      }

      if (!found) {
        newPath = `/en${currentPath === "/" ? "" : currentPath}`;
      }
    }
  } else if (targetLang === "cs") {
    // If it's an English path, find czech path or remove /en prefix
    if (isEnglishPath) {
      let found = false;
      for (const [czBase, enBase] of Object.entries(routeMap)) {
        if (currentPath === enBase) {
          newPath = czBase;
          found = true;
          break;
        } else if (currentPath.startsWith(`${enBase}/`)) {
          newPath = currentPath.replace(enBase, czBase);
          found = true;
          break;
        }
      }

      if (!found) {
        newPath = currentPath.replace(/^\/en(?=\/|$)/, "") || "/";
      }
    }
  }

  return new URL(newPath, Astro.site || "https://www.telperion.cz").href;
};

// Use the base domain without language subdirectory for x-default
const xDefaultUrl = getHreflangUrl("cs");
const csUrl = getHreflangUrl("cs");
const enUrl = getHreflangUrl("en");
const includeAlternateLinks = !noindex;
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Temporary theme lockdown: Always Light Mode
      document.documentElement.classList.remove("dark");
    </script>
    <meta name="description" content={translatedDesc} />
    <meta name="viewport" content="width=device-width" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <meta
      property="og:title"
      content={`${translatedTitle || "Domů"} | Telperion`}
    />
    <meta property="og:description" content={translatedDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    {
      image && (
        <meta
          property="og:image"
          content={
            new URL(image, Astro.site || "https://www.telperion.cz").href
          }
        />
      )
    }

    <meta name="twitter:card" content="summary" />
    <meta
      name="twitter:title"
      content={`${translatedTitle || "Domů"} | Telperion`}
    />
    <meta name="twitter:description" content={translatedDesc} />
    {
      image && (
        <meta
          name="twitter:image"
          content={
            new URL(image, Astro.site || "https://www.telperion.cz").href
          }
        />
      )
    }

    <link rel="canonical" href={canonicalUrl.href} />
    {
      includeAlternateLinks && (
        <link rel="alternate" hreflang="cs" href={csUrl} />
      )
    }
    {
      includeAlternateLinks && (
        <link rel="alternate" hreflang="en" href={enUrl} />
      )
    }
    {
      includeAlternateLinks && (
        <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
      )
    }

    <title>
      {translatedTitle ? `${translatedTitle} | Telperion` : "Telperion"}
    </title>
    <link rel="preconnect" href="https://umap.openstreetmap.fr" crossorigin />
    <link rel="preconnect" href="https://tile.openstreetmap.org" crossorigin />
    <Analytics />
    <SpeedInsights />
  </head>

  <body class="bg-cream text-dark-green font-sans antialiased">
    <div class="relative overflow-hidden flex flex-col min-h-screen">
      <div
        class="absolute top-0 right-0 w-64 md:w-96 opacity-90 pointer-events-none z-0"
      >
        <Image
          src={leaves}
          alt=""
          fetchpriority="high"
          loading="eager"
          width={429}
          height={317}
        />
      </div>
      <div
        class="absolute bottom-0 left-0 rotate-180 w-64 md:w-96 opacity-90 pointer-events-none z-0"
      >
        <Image
          src={leaves}
          alt=""
          fetchpriority="high"
          loading="eager"
          width={429}
          height={317}
        />
      </div>

      <Navbar />

      <main class="flex-grow flex flex-col relative z-10 pt-24 pb-0">
        <slot />
      </main>

      <div class="relative z-20">
        <Footer />
      </div>
    </div>

    <Modal />
    <DonationModal />
  </body>
</html>
